//@version=6
indicator("Amas Quarter Theory", overlay=true,
         max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ Amas Quarter Theory — bootcamp price-action overlay                      ║
// ║ 15m quarters · 1h doji/line · 3h triad line/apex · 05-box bands · midlns ║
// ║                                                                          ║
// ║ NOTE: This is the v1 visual-only build. Probability readouts display     ║
// ║ "—" placeholders; empirical tables wired in a follow-up release.         ║
// ╚══════════════════════════════════════════════════════════════════════════╝


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 1. SETTINGS                                                              ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── ⚙ General ─────────────────────────────────────────────────────────────
G_GENERAL = "⚙ General"
gTheme        = input.string("Dark", "Theme",        options=["Dark","Light","Custom"], group=G_GENERAL)
gDataSource   = input.string("Auto", "Empirical data source (reserved)", options=["Auto","NQ","ES"], group=G_GENERAL,
                              tooltip="Reserved for empirical-table phase. Currently inert.")
gTzNote       = input.string("America/New_York", "Time zone (read-only)", options=["America/New_York"], group=G_GENERAL)

// ── 📊 Live Readouts ─────────────────────────────────────────────────────
G_RO = "📊 Live Readouts"
gReadoutsOn   = input.bool(true,  "▶ Enable group", group=G_RO)
gShow1h       = input.bool(true,  "Show 1h hour readout", group=G_RO)
gShow3h       = input.bool(true,  "Show 3h triad readout", group=G_RO)
gActiveStyle  = input.string("Highlighted + LIVE tag", "Active block style",
                              options=["Highlighted","LIVE tag","Highlighted + LIVE tag"], group=G_RO)
gHistDepth    = input.int(20, "History depth (triads)", minval=1, maxval=40, group=G_RO)
gShowN        = input.bool(true,  "Show sample count (n)", group=G_RO)
gConfColor    = input.bool(true,  "Confidence color on n", group=G_RO)
gShowPath     = input.bool(true,  "Show conditional path %", group=G_RO)
gShowQPair    = input.bool(true,  "Show quarter-pair recommendation", group=G_RO)

// ── 🕐 Quarter Structure ─────────────────────────────────────────────────
G_QS = "🕐 Quarter Structure"
gQStructOn    = input.bool(true,  "▶ Enable group", group=G_QS)
gShowQDiv     = input.bool(true,  "Show quarter dividers (vertical dotted)", group=G_QS)
gShowInStat   = input.bool(true,  "Show in-stat extreme labels (Q1/Q4)", group=G_QS)
gShowOutStat  = input.bool(true,  "Show out-of-stat extreme labels (Q2/Q3)", group=G_QS)
gShowSweepers = input.bool(true,  "Show sweeper markers", group=G_QS)
gShowBiasShift= input.bool(true,  "Show bias-shift markers", group=G_QS)
gShowDojiConf = input.bool(true,  "Show doji-confirmed marker", group=G_QS)

// ── 🕒 Hour & Triad Verdicts ─────────────────────────────────────────────
G_VER = "🕒 Hour & Triad Verdicts"
gVerdictsOn   = input.bool(true,  "▶ Enable group", group=G_VER)
gShowHourVerd = input.bool(true,  "Show hour close verdict", group=G_VER)
gShowTriadVerd= input.bool(true,  "Show triad close verdict", group=G_VER)
gShowApexHr   = input.bool(true,  "Show apex-hour highlight", group=G_VER)
gShowOhlcOver = input.bool(true,  "Show 3h running OHLC overlay", group=G_VER)

// ── 📐 Midlines ───────────────────────────────────────────────────────────
G_MID = "📐 Midlines"
gMidOn        = input.bool(true,  "▶ Enable group", group=G_MID)
gShowMid1h    = input.bool(true,  "Show 1h midline", group=G_MID)
gShowMid3h    = input.bool(true,  "Show 3h midline", group=G_MID)
gShowMidReact = input.bool(false, "Show midline reaction markers", group=G_MID)
gMid1hWidth   = input.int(1, "1h midline width", minval=1, maxval=4, group=G_MID)
gMid3hWidth   = input.int(1, "3h midline width", minval=1, maxval=4, group=G_MID)

// ── 📦 05 Box & Bands ─────────────────────────────────────────────────────
G_BOX = "📦 05 Box & Bands"
gBoxOn        = input.bool(true,  "▶ Enable group", group=G_BOX)
gShowBoxCol   = input.bool(true,  "Show 05 box column (full-height tint)", group=G_BOX)
gShowBand05   = input.bool(true,  "Show ±0.05% bands", group=G_BOX)
gShowBand10   = input.bool(true,  "Show ±0.10% bands", group=G_BOX)
gShowBandRej  = input.bool(true,  "Show band rejection markers", group=G_BOX)
gShowBandLbl  = input.bool(true,  "Show inline % labels (.05% / .1%)", group=G_BOX)

// ── 🔔 Alerts ─────────────────────────────────────────────────────────────
G_AL = "🔔 Alerts"
gAlertsOn     = input.bool(true,  "▶ Enable group", group=G_AL)
gAlertSweep   = input.bool(false, "Alert on sweeper", group=G_AL)
gAlertDoji    = input.bool(true,  "Alert on doji-confirmed", group=G_AL)
gAlertApex    = input.bool(true,  "Alert on apex-confirmed", group=G_AL)
gAlertMid     = input.bool(false, "Alert on midline reaction", group=G_AL)
gAlertBandRej = input.bool(false, "Alert on band rejection", group=G_AL)

// ── 🎨 Custom Colors (only used when Theme = Custom) ─────────────────────
G_COL = "🎨 Custom Colors (active when Theme = Custom)"
gColInStat    = input.color(color.new(#7eb6ff, 0),  "In-stat extreme (navy)", group=G_COL)
gColOutStat   = input.color(color.new(#f59e0b, 0),  "Out-of-stat extreme",  group=G_COL)
gColSweeper   = input.color(color.new(#8b5cf6, 0),  "Sweeper",              group=G_COL)
gColDojiConf  = input.color(color.new(#f59e0b, 0),  "Doji-confirmed",       group=G_COL)
gColApexHr    = input.color(color.new(#ef4444, 0),  "Apex-hour highlight",  group=G_COL)
gColLineUp    = input.color(color.new(#10b981, 0),  "Line-up readout",      group=G_COL)
gColLineDn    = input.color(color.new(#ef4444, 0),  "Line-down readout",    group=G_COL)
gColApexUp    = input.color(color.new(#3b82f6, 0),  "Apex-up readout",      group=G_COL)
gColApexDn    = input.color(color.new(#8b5cf6, 0),  "Apex-down readout",    group=G_COL)
gColDojiRO    = input.color(color.new(#f59e0b, 0),  "Doji readout",         group=G_COL)
gColMid1h     = input.color(color.new(#f59e0b, 0),  "1h midline",           group=G_COL)
gColMid3h     = input.color(color.new(#e2eaf4, 0),  "3h midline",           group=G_COL)
gColBand05    = input.color(color.new(#ffffff, 75), "0.05% band",           group=G_COL)
gColBand10    = input.color(color.new(#ffffff, 50), "0.10% band",           group=G_COL)
gColBoxTint   = input.color(color.new(#ffffff, 94), "05 box tint",          group=G_COL)
gColActiveHr  = input.color(color.new(#06b6d4, 95), "Active hour tint",     group=G_COL)
gColActiveTr  = input.color(color.new(#06b6d4, 97), "Active triad tint",    group=G_COL)
gColQDiv      = input.color(color.new(#ffffff, 88), "Quarter divider",      group=G_COL)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 2. THEME RESOLVER                                                        ║
// ╚══════════════════════════════════════════════════════════════════════════╝

type Theme
    color in_stat
    color out_stat
    color sweeper
    color doji_conf
    color apex_hour
    color line_up
    color line_dn
    color apex_up
    color apex_dn
    color doji
    color mid_1h
    color mid_3h
    color band_05
    color band_10
    color box_tint
    color active_hr
    color active_triad
    color q_div
    color readout_bg
    color readout_border
    color readout_text
    color readout_text_dim
    color readout_active_accent
    color conf_high
    color conf_med
    color conf_low

resolveTheme() =>
    Theme t = na
    if gTheme == "Dark"
        t := Theme.new(
          // In-stat: light navy in Dark mode for legibility against dark bg
          // (the user spec said "dark navy"; we keep navy hue, lighten value)
          in_stat              = color.new(#7eb6ff, 0),
          out_stat             = color.new(#f59e0b, 0),
          sweeper              = color.new(#8b5cf6, 0),
          doji_conf            = color.new(#f59e0b, 0),
          apex_hour            = color.new(#ef4444, 0),
          line_up              = color.new(#10b981, 0),
          line_dn              = color.new(#ef4444, 0),
          apex_up              = color.new(#3b82f6, 0),
          apex_dn              = color.new(#8b5cf6, 0),
          doji                 = color.new(#f59e0b, 0),
          mid_1h               = color.new(#f59e0b, 0),
          mid_3h               = color.new(#e2eaf4, 0),
          band_05              = color.new(#ffffff, 60),
          band_10              = color.new(#ffffff, 30),
          box_tint             = color.new(#ffffff, 92),       // 05 box bg: lighter
          active_hr            = color.new(#cbd5e1, 92),       // light gray (slate-300), neutral
          active_triad         = color.new(#cbd5e1, 95),       // even lighter gray for triad
          q_div                = color.new(#ffffff, 88),
          readout_bg           = color.new(#1a2235, 5),        // bg-raised, near-opaque
          readout_border       = color.new(#ffffff, 75),
          readout_text         = color.new(#e2eaf4, 0),
          readout_text_dim     = color.new(#8ba4bc, 0),
          readout_active_accent= color.new(#06b6d4, 65),
          conf_high            = color.new(#10b981, 0),
          conf_med             = color.new(#f59e0b, 0),
          conf_low             = color.new(#ef4444, 0))
    else if gTheme == "Light"
        t := Theme.new(
          in_stat              = color.new(#0a2540, 0),  // dark navy
          out_stat             = color.new(#d97706, 0),
          sweeper              = color.new(#7c3aed, 0),
          doji_conf            = color.new(#d97706, 0),
          apex_hour            = color.new(#dc2626, 0),
          line_up              = color.new(#059669, 0),
          line_dn              = color.new(#dc2626, 0),
          apex_up              = color.new(#2563eb, 0),
          apex_dn              = color.new(#7c3aed, 0),
          doji                 = color.new(#d97706, 0),
          mid_1h               = color.new(#d97706, 0),
          mid_3h               = color.new(#1f2937, 0),
          band_05              = color.new(#000000, 55),
          band_10              = color.new(#000000, 25),
          box_tint             = color.new(#94a3b8, 92),       // 05 box bg: light slate, lighter
          active_hr            = color.new(#94a3b8, 90),       // light gray (slate-400), neutral
          active_triad         = color.new(#94a3b8, 94),       // lighter gray for triad
          q_div                = color.new(#94a3b8, 92),       // light slate, very faint on white
          readout_bg           = color.new(#f1f5f9, 5),        // slate-100 fill, near-opaque
          readout_border       = color.new(#475569, 50),
          readout_text         = color.new(#0f172a, 0),        // near-black for readability
          readout_text_dim     = color.new(#475569, 0),
          readout_active_accent= color.new(#0891b2, 55),
          conf_high            = color.new(#059669, 0),
          conf_med             = color.new(#d97706, 0),
          conf_low             = color.new(#dc2626, 0))
    else
        t := Theme.new(
          in_stat              = gColInStat,
          out_stat             = gColOutStat,
          sweeper              = gColSweeper,
          doji_conf            = gColDojiConf,
          apex_hour            = gColApexHr,
          line_up              = gColLineUp,
          line_dn              = gColLineDn,
          apex_up              = gColApexUp,
          apex_dn              = gColApexDn,
          doji                 = gColDojiRO,
          mid_1h               = gColMid1h,
          mid_3h               = gColMid3h,
          band_05              = gColBand05,
          band_10              = gColBand10,
          box_tint             = gColBoxTint,
          active_hr            = gColActiveHr,
          active_triad         = gColActiveTr,
          q_div                = gColQDiv,
          readout_bg           = color.new(#111827, 15),
          readout_border       = color.new(#ffffff, 90),
          readout_text         = color.new(#e2eaf4, 0),
          readout_text_dim     = color.new(#8ba4bc, 0),
          readout_active_accent= color.new(#06b6d4, 65),
          conf_high            = color.new(#10b981, 0),
          conf_med             = color.new(#f59e0b, 0),
          conf_low             = color.new(#ef4444, 0))
    t

var Theme T = na
T := resolveTheme()


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 3. TIME / STRUCTURE PRIMITIVES                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

NY_TZ = "America/New_York"

quarterOfHour() =>
    int m = minute(time, NY_TZ)
    int q = m / 15 + 1
    q

blockId() =>
    int h = hour(time, NY_TZ)
    string b = na
    if h < 3
        b := "00-03"
    else if h < 6
        b := "03-06"
    else if h < 9
        b := "06-09"
    else if h < 12
        b := "09-12"
    else if h < 15
        b := "12-15"
    else if h >= 18 and h < 21
        b := "18-21"
    else if h >= 21
        b := "21-00"
    // else 15..17 → b stays na (excluded gap)
    b

hourIndexInTriad() =>
    int h = hour(time, NY_TZ)
    int idx = na
    if h < 3
        idx := h + 1                  // 0,1,2 → 1,2,3 within block 00-03
    else if h < 6
        idx := h - 3 + 1
    else if h < 9
        idx := h - 6 + 1
    else if h < 12
        idx := h - 9 + 1
    else if h < 15
        idx := h - 12 + 1
    else if h >= 18 and h < 21
        idx := h - 18 + 1
    else if h >= 21
        idx := h - 21 + 1
    // else 15..17 → idx stays na
    idx

isFirstBarOfQuarter() =>
    int m = minute(time, NY_TZ)
    m == 0 or m == 15 or m == 30 or m == 45

isLastBarOfQuarter() =>
    int m = minute(time, NY_TZ)
    m == 14 or m == 29 or m == 44 or m == 59

isBoxBar() =>
    int m = minute(time, NY_TZ)
    m <= 4

isHourClose() =>
    minute(time, NY_TZ) == 59

isTriadClose() =>
    isHourClose() and hourIndexInTriad() == 3


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 4. RUNNING AGGREGATIONS                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════╝

type QuarterAgg
    int    qIdx
    int    anchorBar
    float  open_   = na
    float  close_  = na
    float  high_   = na
    float  low_    = na
    int    highBar = na
    int    lowBar  = na
    int    barCount = 0

quarterUpdate(QuarterAgg q, float o, float h, float l, float c) =>
    if not na(q)
        if q.barCount == 0
            q.open_ := o
        q.close_ := c
        if na(q.high_) or h > q.high_
            q.high_   := h
            q.highBar := bar_index
        if na(q.low_) or l < q.low_
            q.low_   := l
            q.lowBar := bar_index
        q.barCount += 1

type HourAgg
    int        anchorBar
    QuarterAgg q1 = na
    QuarterAgg q2 = na
    QuarterAgg q3 = na
    QuarterAgg q4 = na
    float      box05Hi = na
    float      box05Lo = na
    bool       box05Locked = false

hourHigh(HourAgg h) =>
    float hi = na
    if not na(h.q1) and (na(hi) or h.q1.high_ > hi)
        hi := h.q1.high_
    if not na(h.q2) and (na(hi) or h.q2.high_ > hi)
        hi := h.q2.high_
    if not na(h.q3) and (na(hi) or h.q3.high_ > hi)
        hi := h.q3.high_
    if not na(h.q4) and (na(hi) or h.q4.high_ > hi)
        hi := h.q4.high_
    hi

hourLow(HourAgg h) =>
    float lo = na
    if not na(h.q1) and (na(lo) or h.q1.low_ < lo)
        lo := h.q1.low_
    if not na(h.q2) and (na(lo) or h.q2.low_ < lo)
        lo := h.q2.low_
    if not na(h.q3) and (na(lo) or h.q3.low_ < lo)
        lo := h.q3.low_
    if not na(h.q4) and (na(lo) or h.q4.low_ < lo)
        lo := h.q4.low_
    lo

hourMid(HourAgg h) =>
    hi = hourHigh(h)
    lo = hourLow(h)
    na(hi) or na(lo) ? na : (hi + lo) / 2.0

type TriadAgg
    string  blockId
    int     anchorBar
    HourAgg c1 = na
    HourAgg c2 = na
    HourAgg c3 = na

triadHigh(TriadAgg t) =>
    float hi = na
    h1 = na(t.c1) ? na : hourHigh(t.c1)
    h2 = na(t.c2) ? na : hourHigh(t.c2)
    h3 = na(t.c3) ? na : hourHigh(t.c3)
    if not na(h1)
        hi := h1
    if not na(h2) and (na(hi) or h2 > hi)
        hi := h2
    if not na(h3) and (na(hi) or h3 > hi)
        hi := h3
    hi

triadLow(TriadAgg t) =>
    float lo = na
    l1 = na(t.c1) ? na : hourLow(t.c1)
    l2 = na(t.c2) ? na : hourLow(t.c2)
    l3 = na(t.c3) ? na : hourLow(t.c3)
    if not na(l1)
        lo := l1
    if not na(l2) and (na(lo) or l2 < lo)
        lo := l2
    if not na(l3) and (na(lo) or l3 < lo)
        lo := l3
    lo

// One TriadAgg per active 3h block. Reset at the start of each block.
var TriadAgg activeTriad = na

if isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1
    activeTriad := TriadAgg.new(blockId = blockId(), anchorBar = bar_index)

if not na(activeTriad)
    int hidx = hourIndexInTriad()
    if not na(hidx)
        // Lazily create the hour and quarter on first bar of each
        if hidx == 1 and na(activeTriad.c1)
            activeTriad.c1 := HourAgg.new(anchorBar = bar_index)
        if hidx == 2 and na(activeTriad.c2)
            activeTriad.c2 := HourAgg.new(anchorBar = bar_index)
        if hidx == 3 and na(activeTriad.c3)
            activeTriad.c3 := HourAgg.new(anchorBar = bar_index)

        HourAgg curHour = hidx == 1 ? activeTriad.c1 : hidx == 2 ? activeTriad.c2 : activeTriad.c3
        if not na(curHour)
            int qi = quarterOfHour()
            if qi == 1 and na(curHour.q1)
                curHour.q1 := QuarterAgg.new(qIdx = 1, anchorBar = bar_index)
            if qi == 2 and na(curHour.q2)
                curHour.q2 := QuarterAgg.new(qIdx = 2, anchorBar = bar_index)
            if qi == 3 and na(curHour.q3)
                curHour.q3 := QuarterAgg.new(qIdx = 3, anchorBar = bar_index)
            if qi == 4 and na(curHour.q4)
                curHour.q4 := QuarterAgg.new(qIdx = 4, anchorBar = bar_index)
            QuarterAgg curQ = qi == 1 ? curHour.q1 : qi == 2 ? curHour.q2 : qi == 3 ? curHour.q3 : curHour.q4

            if not na(curQ)
                quarterUpdate(curQ, open, high, low, close)

            // 05-box accumulation
            if isBoxBar()
                curHour.box05Hi := na(curHour.box05Hi) ? high : math.max(curHour.box05Hi, high)
                curHour.box05Lo := na(curHour.box05Lo) ? low  : math.min(curHour.box05Lo, low)
                if minute(time, NY_TZ) == 4
                    curHour.box05Locked := true


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 5. CLASSIFIERS                                                           ║
// ╚══════════════════════════════════════════════════════════════════════════╝

classifyHour(HourAgg h) =>
    string cls = "pending"
    if not na(h) and not na(h.q1) and not na(h.q2) and not na(h.q3) and not na(h.q4)
        h1 = h.q1.high_, h2 = h.q2.high_, h3 = h.q3.high_, h4 = h.q4.high_
        l1 = h.q1.low_,  l2 = h.q2.low_,  l3 = h.q3.low_,  l4 = h.q4.low_
        if h1 < h2 and h2 < h3 and h3 < h4 and l1 < l2 and l2 < l3 and l3 < l4
            cls := "line-up"
        else if h1 > h2 and h2 > h3 and h3 > h4 and l1 > l2 and l2 > l3 and l3 > l4
            cls := "line-down"
        else
            cls := "doji"
    cls

classifyTriad(TriadAgg t) =>
    string cls = "pending"
    if not na(t) and not na(t.c1) and not na(t.c2) and not na(t.c3)
        h1 = hourHigh(t.c1), h2 = hourHigh(t.c2), h3 = hourHigh(t.c3)
        l1 = hourLow(t.c1),  l2 = hourLow(t.c2),  l3 = hourLow(t.c3)
        if not na(h1) and not na(h2) and not na(h3) and not na(l1) and not na(l2) and not na(l3)
            if h1 < h2 and h2 < h3 and l1 < l2 and l2 < l3
                cls := "line-up"
            else if h1 > h2 and h2 > h3 and l1 > l2 and l2 > l3
                cls := "line-down"
            else if h1 < h2 and h2 > h3
                cls := "apex-up"
            else if l1 > l2 and l2 < l3
                cls := "apex-down"
            else
                cls := "doji"
    cls


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 6. RENDERERS                                                             ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ── Hour box (bounded to hour range) + intra-hour quarter verticals ───────
// Hour box: tinted rectangle bounded by the hour's running high/low, growing
// with each bar. Quarter verticals at :15, :30, :45 are thin solid lines
// confined to within the active hour's price range.

// Hour box bg renders as the q_div tint at its native opacity (already faint).
// Quarter divider verticals lean a bit darker than the box for distinction.
hourBoxBg() => T.q_div
hourDivLine() => color.new(T.q_div, math.max(0, color.t(T.q_div) - 25))

// One box + 3 quarter-divider lines per hour, updated live as range expands
var box currentHourBox = na
var line currentQ2Line = na
var line currentQ3Line = na
var line currentQ4Line = na

// Reset / create at hour open (first bar of Q1 with valid block)
if gQStructOn and gShowQDiv and isFirstBarOfQuarter() and quarterOfHour() == 1 and not na(blockId())
    int barsPerHourDiv = math.max(1, int(60 * 60 / timeframe.in_seconds("")))
    currentHourBox := box.new(left=bar_index, top=high, right=bar_index + barsPerHourDiv - 1, bottom=low,
                              xloc=xloc.bar_index, bgcolor=hourBoxBg(),
                              border_color=color.new(T.q_div, 100), border_width=0)
    currentQ2Line := na
    currentQ3Line := na
    currentQ4Line := na

// Update every bar inside the active hour: expand top/bottom to running range
if gQStructOn and gShowQDiv and not na(currentHourBox) and not na(blockId()) and not na(hourIndexInTriad())
    new_top    = math.max(box.get_top(currentHourBox),    high)
    new_bottom = math.min(box.get_bottom(currentHourBox), low)
    box.set_top(currentHourBox, new_top)
    box.set_bottom(currentHourBox, new_bottom)
    // Sync any existing quarter divider lines to match new top/bottom
    if not na(currentQ2Line)
        line.set_y1(currentQ2Line, new_bottom)
        line.set_y2(currentQ2Line, new_top)
    if not na(currentQ3Line)
        line.set_y1(currentQ3Line, new_bottom)
        line.set_y2(currentQ3Line, new_top)
    if not na(currentQ4Line)
        line.set_y1(currentQ4Line, new_bottom)
        line.set_y2(currentQ4Line, new_top)

// Spawn quarter divider line at start of Q2/Q3/Q4
if gQStructOn and gShowQDiv and isFirstBarOfQuarter() and not na(blockId()) and not na(currentHourBox)
    int qNew = quarterOfHour()
    float yTop = box.get_top(currentHourBox)
    float yBot = box.get_bottom(currentHourBox)
    if qNew == 2
        currentQ2Line := line.new(bar_index, yBot, bar_index, yTop, xloc=xloc.bar_index,
                                  extend=extend.none, color=hourDivLine(), style=line.style_solid, width=1)
    if qNew == 3
        currentQ3Line := line.new(bar_index, yBot, bar_index, yTop, xloc=xloc.bar_index,
                                  extend=extend.none, color=hourDivLine(), style=line.style_solid, width=1)
    if qNew == 4
        currentQ4Line := line.new(bar_index, yBot, bar_index, yTop, xloc=xloc.bar_index,
                                  extend=extend.none, color=hourDivLine(), style=line.style_solid, width=1)

// ── 05-box (bounded to box range, extends horizontally across the hour) ──
// One box, anchored to the active hour's box high/low. Box high/low is locked
// at minute :04; the rectangle extends horizontally to the end of the hour.
var box current05Box = na

if gBoxOn and gShowBoxCol and isFirstBarOfQuarter() and quarterOfHour() == 1 and not na(blockId())
    int barsPerHour05 = math.max(1, int(60 * 60 / timeframe.in_seconds("")))
    current05Box := box.new(left=bar_index, top=high, right=bar_index + barsPerHour05 - 1, bottom=low,
                            xloc=xloc.bar_index, bgcolor=T.box_tint,
                            border_color=color.new(T.box_tint, math.max(0, color.t(T.box_tint) - 10)),
                            border_width=1, border_style=line.style_solid)

// Update 05-box bounds during minutes :00–:04 (box high/low locks after :04)
if gBoxOn and gShowBoxCol and isBoxBar() and not na(current05Box) and not na(blockId())
    new_top_05    = math.max(box.get_top(current05Box),    high)
    new_bottom_05 = math.min(box.get_bottom(current05Box), low)
    box.set_top(current05Box, new_top_05)
    box.set_bottom(current05Box, new_bottom_05)

// ── ±0.05% / ±0.10% bands (drawn on the :04 minute when box locks) ────────
bandLevels(float boxHi, float boxLo) =>
    [boxHi * 1.0010, boxHi * 1.0005, boxLo * 0.9995, boxLo * 0.9990]

if gBoxOn and not na(activeTriad)
    int hidx = hourIndexInTriad()
    HourAgg curH = hidx == 1 ? activeTriad.c1 : hidx == 2 ? activeTriad.c2 : hidx == 3 ? activeTriad.c3 : na
    if not na(curH) and curH.box05Locked and minute(time, NY_TZ) == 4 and not na(curH.box05Hi)
        [u10, u05, l05_, l10] = bandLevels(curH.box05Hi, curH.box05Lo)
        int hourStartBar = curH.anchorBar
        // Bands extend only through the rest of Q1 — i.e. up to and including
        // minute :14 of the hour. They are NOT drawn through Q2/Q3/Q4.
        int barsPerQuarter = math.max(1, int(15 * 60 / timeframe.in_seconds("")))
        int q1EndBar = curH.anchorBar + barsPerQuarter - 1
        if gShowBand10
            line.new(hourStartBar, u10, q1EndBar, u10, xloc=xloc.bar_index, color=T.band_10, style=line.style_dotted, width=2)
            line.new(hourStartBar, l10, q1EndBar, l10, xloc=xloc.bar_index, color=T.band_10, style=line.style_dotted, width=2)
            if gShowBandLbl
                label.new(q1EndBar, u10, ".1%", xloc=xloc.bar_index, color=color.new(T.band_10, 100), textcolor=T.band_10, style=label.style_label_left, size=size.small)
                label.new(q1EndBar, l10, ".1%", xloc=xloc.bar_index, color=color.new(T.band_10, 100), textcolor=T.band_10, style=label.style_label_left, size=size.small)
        if gShowBand05
            line.new(hourStartBar, u05, q1EndBar, u05, xloc=xloc.bar_index, color=T.band_05, style=line.style_dotted, width=1)
            line.new(hourStartBar, l05_, q1EndBar, l05_, xloc=xloc.bar_index, color=T.band_05, style=line.style_dotted, width=1)
            if gShowBandLbl
                label.new(q1EndBar, u05, ".05%", xloc=xloc.bar_index, color=color.new(T.band_05, 100), textcolor=T.band_05, style=label.style_label_left, size=size.small)
                label.new(q1EndBar, l05_, ".05%", xloc=xloc.bar_index, color=color.new(T.band_05, 100), textcolor=T.band_05, style=label.style_label_left, size=size.small)

// ── Band rejection markers ────────────────────────────────────────────────
detectBandRejection(float h, float l, float c, float u10, float u05, float l05_, float l10) =>
    string side = "", level = ""
    if h > u10 and c < u10
        side := "upper"
        level := "10"
    else if h > u05 and c < u05
        side := "upper"
        level := "05"
    else if l < l10 and c > l10
        side := "lower"
        level := "10"
    else if l < l05_ and c > l05_
        side := "lower"
        level := "05"
    [side, level]

var string boxReactState = "none"
// Per-band first-rejection flags. Reset at hour open, set true after first hit.
var bool rejFired10Up = false
var bool rejFired10Dn = false
var bool rejFired05Up = false
var bool rejFired05Dn = false

if gBoxOn and not na(activeTriad)
    int hidx_br = hourIndexInTriad()
    HourAgg curH_br = hidx_br == 1 ? activeTriad.c1 : hidx_br == 2 ? activeTriad.c2 : hidx_br == 3 ? activeTriad.c3 : na
    if not na(curH_br) and curH_br.box05Locked and not na(curH_br.box05Hi)
        [u10b, u05b, l05b, l10b] = bandLevels(curH_br.box05Hi, curH_br.box05Lo)
        [side, level] = detectBandRejection(high, low, close, u10b, u05b, l05b, l10b)
        if side != ""
            // Update box-react state used in readouts
            string token = level + (side == "upper" ? "up_rejected" : "dn_rejected")
            if boxReactState == "none" or boxReactState == token
                boxReactState := token
            else
                boxReactState := "multi"

            // Only mark the FIRST rejection of each (level, side) per hour.
            bool isFirst = (level == "10" and side == "upper" and not rejFired10Up) or
                           (level == "10" and side == "lower" and not rejFired10Dn) or
                           (level == "05" and side == "upper" and not rejFired05Up) or
                           (level == "05" and side == "lower" and not rejFired05Dn)

            if isFirst
                if level == "10" and side == "upper"
                    rejFired10Up := true
                if level == "10" and side == "lower"
                    rejFired10Dn := true
                if level == "05" and side == "upper"
                    rejFired05Up := true
                if level == "05" and side == "lower"
                    rejFired05Dn := true

                if gShowBandRej
                    color cMark = level == "10" ? T.band_10 : T.band_05
                    float anchorY = side == "upper" ? high : low
                    label.new(bar_index, anchorY, "rej " + level,
                              style=side == "upper" ? label.style_label_down : label.style_label_up,
                              color=color.new(cMark, 95), textcolor=cMark, size=size.small)
                if gAlertsOn and gAlertBandRej
                    alert("Quarter Theory: " + level + "% band " + side + " rejection", alert.freq_once_per_bar)

// Reset per-hour state at hour open
if isFirstBarOfQuarter() and quarterOfHour() == 1
    boxReactState := "none"
    rejFired10Up := false
    rejFired10Dn := false
    rejFired05Up := false
    rejFired05Dn := false

// ── 1h midline + reactions ────────────────────────────────────────────────
resolve1hMid(HourAgg cur, HourAgg prior) =>
    float mid = na
    string source = "current"
    if not na(cur)
        curHi = hourHigh(cur)
        curLo = hourLow(cur)
        if not na(curHi) and not na(curLo)
            if not na(prior)
                prHi = hourHigh(prior)
                prLo = hourLow(prior)
                if not na(prHi) and not na(prLo) and curLo > prLo and curHi < prHi
                    mid := (prHi + prLo) / 2.0
                    source := "prior"
                else
                    mid := (curHi + curLo) / 2.0
            else
                mid := (curHi + curLo) / 2.0
    [mid, source]

resolve3hMid(TriadAgg cur, float priorTriadHi, float priorTriadLo) =>
    float mid = na
    string source = "current"
    if not na(cur)
        curHi = triadHigh(cur)
        curLo = triadLow(cur)
        if not na(curHi) and not na(curLo)
            if not na(priorTriadHi) and not na(priorTriadLo) and curLo > priorTriadLo and curHi < priorTriadHi
                mid := (priorTriadHi + priorTriadLo) / 2.0
                source := "prior"
            else
                mid := (curHi + curLo) / 2.0
    [mid, source]

detectMidReaction(float mid, float h, float l, float c) =>
    string r = ""
    if not na(mid)
        if l < mid and c > mid
            r := "support"
        else if h > mid and c < mid
            r := "reject"
    r

var HourAgg priorHour1h = na
var float priorTriadHi  = na
var float priorTriadLo  = na
var string midhrState   = "untouched"
var string mid3hState   = "untouched"
var string lastMidhrReaction = "none"   // dedup
var string lastMid3hReaction = "none"

// Reset on hour and triad rollovers
if isFirstBarOfQuarter() and quarterOfHour() == 1
    midhrState := "untouched"
    lastMidhrReaction := "none"
if isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1
    mid3hState := "untouched"
    lastMid3hReaction := "none"

// Compute current 1h mid + reaction
float curMid1h = na
if not na(activeTriad)
    int hidx_m = hourIndexInTriad()
    HourAgg curH_m = hidx_m == 1 ? activeTriad.c1 : hidx_m == 2 ? activeTriad.c2 : hidx_m == 3 ? activeTriad.c3 : na
    if not na(curH_m)
        [m1, _src1] = resolve1hMid(curH_m, priorHour1h)
        curMid1h := m1
        if not na(curMid1h)
            r1 = detectMidReaction(curMid1h, high, low, close)
            if r1 != "" and r1 != lastMidhrReaction
                midhrState := r1
                lastMidhrReaction := r1
                if gMidOn and gShowMidReact
                    if r1 == "support"
                        label.new(bar_index, low, "●", style=label.style_label_up,
                                  color=color.new(T.mid_1h, 90), textcolor=T.mid_1h, size=size.small)
                    else
                        label.new(bar_index, high, "●", style=label.style_label_down,
                                  color=color.new(T.mid_1h, 90), textcolor=T.mid_1h, size=size.small)
                if gAlertsOn and gAlertMid
                    alert("Quarter Theory: 1h midline " + r1, alert.freq_once_per_bar)

// Compute current 3h mid + reaction
float curMid3h = na
if not na(activeTriad)
    [m3, _src3] = resolve3hMid(activeTriad, priorTriadHi, priorTriadLo)
    curMid3h := m3
    if not na(curMid3h)
        r3 = detectMidReaction(curMid3h, high, low, close)
        if r3 != "" and r3 != lastMid3hReaction
            mid3hState := r3
            lastMid3hReaction := r3
            // (Same alert path as 1h, no separate marker by default)
            if gAlertsOn and gAlertMid
                alert("Quarter Theory: 3h midline " + r3, alert.freq_once_per_bar)

// Draw midlines as ONE line per hour (1h) and ONE per triad (3h), updated
// in-place as the running mid drifts. New objects spawn at hour/triad open.
var line currentMid1hLine = na
var line currentMid3hLine = na

// Reset / spawn 1h midline at hour open
if gMidOn and gShowMid1h and isFirstBarOfQuarter() and quarterOfHour() == 1 and not na(blockId())
    int barsPerHourMid = math.max(1, int(60 * 60 / timeframe.in_seconds("")))
    currentMid1hLine := line.new(bar_index, na, bar_index + barsPerHourMid - 1, na,
                                 xloc=xloc.bar_index, color=T.mid_1h,
                                 width=gMid1hWidth, style=line.style_solid)

// Reset / spawn 3h midline at triad open (first bar of C1)
if gMidOn and gShowMid3h and isFirstBarOfQuarter() and quarterOfHour() == 1 and hourIndexInTriad() == 1 and not na(blockId())
    int barsPerTriadMid = math.max(1, int(3 * 60 * 60 / timeframe.in_seconds("")))
    currentMid3hLine := line.new(bar_index, na, bar_index + barsPerTriadMid - 1, na,
                                 xloc=xloc.bar_index, color=T.mid_3h,
                                 width=gMid3hWidth, style=line.style_solid)

// Update y-coords each bar so the line follows the running mid
if gMidOn and gShowMid1h and not na(currentMid1hLine) and not na(curMid1h)
    line.set_y1(currentMid1hLine, curMid1h)
    line.set_y2(currentMid1hLine, curMid1h)

if gMidOn and gShowMid3h and not na(currentMid3hLine) and not na(curMid3h)
    line.set_y1(currentMid3hLine, curMid3h)
    line.set_y2(currentMid3hLine, curMid3h)


// ── Sweepers + bias-shifts + doji-confirmed ───────────────────────────────
detectSweepsForQuarter(HourAgg h, int byQ) =>
    string events = ""
    int newBias = 0
    QuarterAgg byQuarter = byQ == 2 ? h.q2 : byQ == 3 ? h.q3 : h.q4
    if not na(byQuarter)
        for tQ = 1 to byQ - 1
            QuarterAgg targ = tQ == 1 ? h.q1 : tQ == 2 ? h.q2 : h.q3
            if not na(targ)
                if byQuarter.high_ > targ.high_
                    events := events + "Q" + str.tostring(int(byQ)) + "→Q" + str.tostring(int(tQ)) + " high  "
                    newBias := newBias != -1 ? 1 : 0
                if byQuarter.low_ < targ.low_
                    events := events + "Q" + str.tostring(int(byQ)) + "→Q" + str.tostring(int(tQ)) + " low  "
                    newBias := newBias != 1 ? -1 : 0
    [events, newBias]

var int lastSweepBias = 0
var bool dojiConfirmedThisHour = false

if isFirstBarOfQuarter() and quarterOfHour() == 1
    lastSweepBias := 0
    dojiConfirmedThisHour := false

if gQStructOn and isLastBarOfQuarter() and not na(activeTriad)
    int hidx_sw = hourIndexInTriad()
    HourAgg curH_sw = hidx_sw == 1 ? activeTriad.c1 : hidx_sw == 2 ? activeTriad.c2 : hidx_sw == 3 ? activeTriad.c3 : na
    int byQ = quarterOfHour()
    if not na(curH_sw) and byQ >= 2
        [events, newBias] = detectSweepsForQuarter(curH_sw, byQ)
        if events != ""
            // Detect doji-confirmed (bias flip within hour)
            if newBias != 0
                if lastSweepBias != 0 and lastSweepBias != newBias
                    dojiConfirmedThisHour := true
                    if gShowDojiConf
                        label.new(bar_index, low, "◆ doji-confirmed", xloc=xloc.bar_index,
                                  style=label.style_label_up, color=color.new(T.doji_conf, 80),
                                  textcolor=T.doji_conf, size=size.small)
                    if gAlertsOn and gAlertDoji
                        alert("Quarter Theory: doji-confirmed in current hour", alert.freq_once_per_bar)
                lastSweepBias := newBias

            if gShowSweepers
                color cSwLabel = T.sweeper
                label.new(bar_index, newBias > 0 ? high : low,
                          "Q" + str.tostring(int(byQ)) + " sweep",
                          xloc=xloc.bar_index,
                          style=newBias > 0 ? label.style_label_down : label.style_label_up,
                          color=color.new(cSwLabel, 92), textcolor=cSwLabel, size=size.small,
                          tooltip="Sweeps:\n" + events)
            if gShowBiasShift and newBias != 0
                color cArr = newBias > 0 ? T.line_up : T.line_dn
                string arr = newBias > 0 ? "▲" : "▼"
                label.new(bar_index, newBias > 0 ? high : low, arr, xloc=xloc.bar_index,
                          style=label.style_label_left,
                          color=color.new(cArr, 100), textcolor=cArr, size=size.small)
            if gAlertsOn and gAlertSweep
                alert("Quarter Theory: sweeper Q" + str.tostring(int(byQ)), alert.freq_once_per_bar)


// ── In-stat / out-of-stat extreme labels (drawn at hour close) ────────────
if gQStructOn and isHourClose() and not na(activeTriad)
    int hidx_ex = hourIndexInTriad()
    HourAgg justClosed = hidx_ex == 1 ? activeTriad.c1 : hidx_ex == 2 ? activeTriad.c2 : activeTriad.c3
    if not na(justClosed) and not na(justClosed.q1) and not na(justClosed.q2) and not na(justClosed.q3) and not na(justClosed.q4)
        float hi = hourHigh(justClosed)
        float lo = hourLow(justClosed)
        // Earliest quarter holding the extreme (matches Python tie-break)
        QuarterAgg qHi = na
        QuarterAgg qLo = na
        for q_idx = 1 to 4
            QuarterAgg qx = q_idx == 1 ? justClosed.q1 : q_idx == 2 ? justClosed.q2 : q_idx == 3 ? justClosed.q3 : justClosed.q4
            if na(qHi) and qx.high_ == hi
                qHi := qx
            if na(qLo) and qx.low_ == lo
                qLo := qx
        if not na(qHi) and not na(qLo)
            bool inStatHi = qHi.qIdx == 1 or qHi.qIdx == 4
            bool inStatLo = qLo.qIdx == 1 or qLo.qIdx == 4

            // Text always renders dark; background is a tinted fill for legibility.
            color textHi = inStatHi ? T.in_stat : T.out_stat
            color textLo = inStatLo ? T.in_stat : T.out_stat
            color bgHi   = color.new(textHi, 80)
            color bgLo   = color.new(textLo, 80)
            if (inStatHi and gShowInStat) or (not inStatHi and gShowOutStat)
                string txtHi = "Q" + str.tostring(qHi.qIdx) + (inStatHi ? " in-stat high" : " out-of-stat high")
                label.new(qHi.highBar, qHi.high_, txtHi, xloc=xloc.bar_index,
                          style=label.style_label_down, color=bgHi,
                          textcolor=textHi, size=size.small)
            if (inStatLo and gShowInStat) or (not inStatLo and gShowOutStat)
                string txtLo = "Q" + str.tostring(qLo.qIdx) + (inStatLo ? " in-stat low" : " out-of-stat low")
                label.new(qLo.lowBar, qLo.low_, txtLo, xloc=xloc.bar_index,
                          style=label.style_label_up, color=bgLo,
                          textcolor=textLo, size=size.small)


// ── Hour close verdicts ───────────────────────────────────────────────────
if gVerdictsOn and gShowHourVerd and isHourClose() and not na(activeTriad)
    int hidx_v = hourIndexInTriad()
    HourAgg justClosedV = hidx_v == 1 ? activeTriad.c1 : hidx_v == 2 ? activeTriad.c2 : activeTriad.c3
    if not na(justClosedV)
        cls = classifyHour(justClosedV)
        if cls != "pending"
            color c = cls == "line-up" ? T.line_up : cls == "line-down" ? T.line_dn : T.doji
            label.new(bar_index, hourLow(justClosedV), cls + " hour", xloc=xloc.bar_index,
                      style=label.style_label_up, color=color.new(c, 92),
                      textcolor=c, size=size.small)


// ── Triad close verdicts + apex-hour highlight ────────────────────────────
if gVerdictsOn and isTriadClose() and not na(activeTriad)
    cls_t = classifyTriad(activeTriad)
    if cls_t != "pending"
        color ct = cls_t == "line-up" ? T.line_up :
                   cls_t == "line-down" ? T.line_dn :
                   cls_t == "apex-up" ? T.apex_up :
                   cls_t == "apex-down" ? T.apex_dn :
                   T.doji
        if gShowTriadVerd
            label.new(bar_index, triadLow(activeTriad), cls_t + " triad", xloc=xloc.bar_index,
                      style=label.style_label_up, color=color.new(ct, 88),
                      textcolor=ct, size=size.small)
        if gShowApexHr and (cls_t == "apex-up" or cls_t == "apex-down") and not na(activeTriad.c2)
            int c2Q1Bar = na(activeTriad.c2.q1) ? activeTriad.c2.anchorBar : activeTriad.c2.q1.anchorBar
            int c2Q4Bar = na(activeTriad.c2.q4) ? bar_index : activeTriad.c2.q4.anchorBar + 14
            box.new(c2Q1Bar, hourHigh(activeTriad.c2), c2Q4Bar, hourLow(activeTriad.c2),
                    xloc=xloc.bar_index, bgcolor=color.new(T.apex_hour, 92),
                    border_color=color.new(T.apex_hour, 70), border_width=1)
            label.new(c2Q4Bar, hourLow(activeTriad.c2), "apex hour", xloc=xloc.bar_index,
                      style=label.style_label_up, color=color.new(T.apex_hour, 80),
                      textcolor=T.apex_hour, size=size.small)
        if gAlertsOn and gAlertApex and (cls_t == "apex-up" or cls_t == "apex-down")
            alert("Quarter Theory: " + cls_t + " confirmed for triad " + activeTriad.blockId, alert.freq_once_per_bar)


// ── Save prior hour / prior triad on close ────────────────────────────────
if isHourClose() and not na(activeTriad)
    int hidx_pc = hourIndexInTriad()
    HourAgg justC = hidx_pc == 1 ? activeTriad.c1 : hidx_pc == 2 ? activeTriad.c2 : activeTriad.c3
    priorHour1h := justC
if isTriadClose() and not na(activeTriad)
    priorTriadHi := triadHigh(activeTriad)
    priorTriadLo := triadLow(activeTriad)


// ── Active hour & triad tints (bounded to their respective ranges) ────────
var box activeHourTint = na
var box activeTriadTint = na

if gReadoutsOn and not na(activeTriad)
    int hidx_t = hourIndexInTriad()
    HourAgg curH_t = hidx_t == 1 ? activeTriad.c1 : hidx_t == 2 ? activeTriad.c2 : hidx_t == 3 ? activeTriad.c3 : na

    // Active hour: bounded to current hour's running high/low
    if not na(curH_t)
        float curHi = hourHigh(curH_t)
        float curLo = hourLow(curH_t)
        if not na(curHi) and not na(curLo)
            if not na(activeHourTint)
                box.delete(activeHourTint)
            activeHourTint := box.new(curH_t.anchorBar, curHi, bar_index, curLo,
                                      xloc=xloc.bar_index, bgcolor=T.active_hr,
                                      border_color=color.new(T.active_hr, 100), border_width=0)

    // Active triad: bounded to triad's running high/low
    float trHi = triadHigh(activeTriad)
    float trLo = triadLow(activeTriad)
    if not na(trHi) and not na(trLo)
        if not na(activeTriadTint)
            box.delete(activeTriadTint)
        activeTriadTint := box.new(activeTriad.anchorBar, trHi, bar_index, trLo,
                                   xloc=xloc.bar_index, bgcolor=T.active_triad,
                                   border_color=color.new(T.active_triad, 100), border_width=0)


// ── 1h hour readout (single styled label, anchored below price) ───────────
// Use a single label with styled background. Position: ATR-offset below the
// active hour's running low, horizontally centered on the active hour.
atrOffset() => ta.atr(20) * 2.0

var label activeHourReadout = na

if gReadoutsOn and gShow1h and not na(activeTriad)
    int hidx_ro = hourIndexInTriad()
    HourAgg curH_ro = hidx_ro == 1 ? activeTriad.c1 : hidx_ro == 2 ? activeTriad.c2 : hidx_ro == 3 ? activeTriad.c3 : na
    if not na(curH_ro) and not na(hourLow(curH_ro))
        string roTitle = "HOUR " + str.tostring(hour(time, NY_TZ)) + ":00 · Q" + str.tostring(int(quarterOfHour()))
        string roProb  = "L-up — · L-dn — · Doji —" + (gShowN ? "  n=—" : "")
        string roState = "midhr: " + midhrState + (boxReactState != "none" ? "  ·  box: " + boxReactState : "")
        string roText  = roTitle + "\n" + roProb + "\n" + roState

        float yPos = hourLow(curH_ro) - atrOffset()
        int barsPerHourRO = math.max(1, int(60 * 60 / timeframe.in_seconds("")))
        int centerBar = curH_ro.anchorBar + barsPerHourRO / 2

        if not na(activeHourReadout)
            label.delete(activeHourReadout)
        activeHourReadout := label.new(centerBar, yPos, roText, xloc=xloc.bar_index,
                                       style=label.style_label_up,
                                       color=T.readout_bg,
                                       textcolor=T.readout_text, size=size.small,
                                       tooltip="Active hour state · midline reactions and 05-box rejections shown live")


// ── 3h triad readout (single styled label, below the hour readout) ────────
var label activeTriadReadout = na
var array<label> completedTriadReadouts = array.new<label>()

if gReadoutsOn and gShow3h and not na(activeTriad)
    string trCls = classifyTriad(activeTriad)
    string trTitle = "TRIAD " + activeTriad.blockId + " · C" + str.tostring(int(hourIndexInTriad())) +
                     " · " + (trCls == "pending" ? "tracking" : trCls)
    string trState = "mid3h: " + mid3hState + "  ·  midhr: " + midhrState
    string trProb  = "L-up — · A-up — · Doji — · L-dn — · A-dn —" + (gShowN ? "  n=—" : "")
    string trText  = trTitle + "\n" + trState + "\n" + trProb

    float lowestY = na
    if not na(activeTriad.c1)
        lowestY := hourLow(activeTriad.c1)
    if not na(activeTriad.c2)
        l2 = hourLow(activeTriad.c2)
        if not na(l2) and (na(lowestY) or l2 < lowestY)
            lowestY := l2
    if not na(activeTriad.c3)
        l3 = hourLow(activeTriad.c3)
        if not na(l3) and (na(lowestY) or l3 < lowestY)
            lowestY := l3
    if not na(lowestY)
        float yPos2 = lowestY - atrOffset() * 3.5
        int barsPerHour2 = math.max(1, int(60 * 60 / timeframe.in_seconds("")))
        int centerBar2 = activeTriad.anchorBar + (barsPerHour2 * 3) / 2

        if not na(activeTriadReadout)
            label.delete(activeTriadReadout)
        activeTriadReadout := label.new(centerBar2, yPos2, trText, xloc=xloc.bar_index,
                                        style=label.style_label_up,
                                        color=T.readout_bg,
                                        textcolor=T.readout_text, size=size.small,
                                        tooltip="Active triad state · block=" + activeTriad.blockId +
                                                "\nClass so far: " + trCls)


// ── 3h running OHLC + flip-level overlay ──────────────────────────────────
flipLevels(TriadAgg t) =>
    string txt = "—"
    if not na(t) and not na(t.c1) and not na(t.c2)
        h2 = hourHigh(t.c2)
        l2 = hourLow(t.c2)
        cls = classifyTriad(t)
        if cls == "pending" and not na(h2) and not na(l2)
            txt := "C3 line-up: > " + str.tostring(h2, format.mintick) +
                   " · apex-up: < " + str.tostring(h2, format.mintick) +
                   "  |  line-dn: < " + str.tostring(l2, format.mintick) +
                   " · apex-dn: > " + str.tostring(l2, format.mintick)
    txt

var label ohlcOverlay = na

if gVerdictsOn and gShowOhlcOver and not na(activeTriad)
    string c1s = na(activeTriad.c1) ? "-" : (str.tostring(hourHigh(activeTriad.c1), format.mintick) + "/" + str.tostring(hourLow(activeTriad.c1), format.mintick))
    string c2s = na(activeTriad.c2) ? "-" : (str.tostring(hourHigh(activeTriad.c2), format.mintick) + "/" + str.tostring(hourLow(activeTriad.c2), format.mintick))
    string c3s = na(activeTriad.c3) ? "(forming)" : (str.tostring(hourHigh(activeTriad.c3), format.mintick) + "/" + str.tostring(hourLow(activeTriad.c3), format.mintick))
    string ohlc = "C1 " + c1s + "  |  C2 " + c2s + "  |  C3 " + c3s
    string flip = flipLevels(activeTriad)
    string txt = ohlc + "\n" + flip

    if not na(ohlcOverlay)
        label.delete(ohlcOverlay)
    ohlcOverlay := label.new(bar_index, high, txt,
                             xloc=xloc.bar_index, style=label.style_label_left,
                             color=color.new(T.readout_bg, 30),
                             textcolor=T.readout_text_dim, size=size.small)


// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ 7. LABEL HOUSEKEEPING (FIFO under history_depth)                         ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// On triad close: archive the active readout into the completed FIFO; trim oldest
// when over the history depth limit. Pine's max_*_count caps also act as a
// hard backstop (set to 500 in indicator() above).
if isTriadClose() and not na(activeTriad)
    if not na(activeTriadReadout)
        array.push(completedTriadReadouts, activeTriadReadout)
        activeTriadReadout := na
    while array.size(completedTriadReadouts) > gHistDepth
        oldL = array.shift(completedTriadReadouts)
        if not na(oldL)
            label.delete(oldL)
