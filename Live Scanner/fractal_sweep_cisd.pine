//@version=5
indicator("Abhi's Fractal Sweep", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ── INPUTS ────────────────────────────────────────────────────────────────────
var string G2 = "Filters"
sweep_min     = input.float(0.10, "Sweep Min %", group=G2, step=0.05) / 100
sweep_max     = input.float(1.50, "Sweep Max %", group=G2, step=0.05) / 100
min_risk      = input.float(3.0,  "Min Risk (pts)", group=G2)
cisd_lookback = input.int(8,      "CISD Lookback Bars", group=G2)
rth_only      = input.bool(true,  "RTH Only (07:00-16:00 ET)", group=G2)

var string G3 = "R:R Box"
rr_extend      = input.int(20,    "Box Width (bars)", group=G3, minval=5, maxval=100)
rr_ratio       = input.float(1.0, "R:R Target", group=G3, step=0.5, minval=0.5, tooltip="e.g. 2 = TP at 2R")
rr_risk_col    = input.color(color.new(color.red,  85), "Risk Zone Fill",    group=G3)
rr_risk_border = input.color(color.new(color.red,  40), "Risk Zone Border",  group=G3)
rr_rew_col     = input.color(color.new(color.teal, 85), "Reward Zone Fill",  group=G3)
rr_rew_border  = input.color(color.new(color.teal, 40), "Reward Zone Border", group=G3)
rr_entry_col   = input.color(color.white,               "Entry Line Color",  group=G3)

var string G4 = "Sweep Line"
sweep_style_inp = input.string("Dotted",   "Line Style",     options=["Dotted", "Dashed", "Solid"], group=G4)
sweep_text      = input.string("Sweep of", "Label Text",     group=G4, tooltip="TF is appended automatically")
sweep_lbl_pos   = input.string("Right",    "Label Position", options=["Left", "Right"], group=G4)

var string G5 = "CISD Line"
cisd_style_inp  = input.string("Dotted", "Line Style",     options=["Dotted", "Dashed", "Solid"], group=G5)
cisd_text       = input.string("CISD",   "Label Text",     group=G5, tooltip="TF is appended automatically")
cisd_lbl_pos    = input.string("Right",  "Label Position", options=["Left", "Right"], group=G5)

var string G6 = "R:R Labels"
rr_lbl_pos    = input.string("Right",                        "Label Position", options=["Left", "Right"], group=G6)
rr_lbl_tp_col = input.color(color.new(color.teal, 20), "TP Label Color",    group=G6)
rr_lbl_sl_col = input.color(color.new(color.red,  20), "SL Label Color",    group=G6)
rr_lbl_en_col = input.color(color.new(color.gray, 60), "Entry Label Color", group=G6)

// ── STYLE HELPERS ─────────────────────────────────────────────────────────────
// "Right" → anchor at END of line, text flows right → style_label_left
// "Left"  → anchor at START of line, text flows left → style_label_right
sweep_lstyle    = sweep_style_inp == "Dashed" ? line.style_dashed : sweep_style_inp == "Solid" ? line.style_solid : line.style_dotted
cisd_lstyle     = cisd_style_inp  == "Dashed" ? line.style_dashed : cisd_style_inp  == "Solid" ? line.style_solid : line.style_dotted
sweep_lbl_style = sweep_lbl_pos == "Right" ? label.style_label_left  : label.style_label_right
cisd_lbl_style  = cisd_lbl_pos  == "Right" ? label.style_label_left  : label.style_label_right
rr_lbl_style    = rr_lbl_pos    == "Right" ? label.style_label_left  : label.style_label_right
// x-position offset: Right = end of line, Left = start of line
sweep_lbl_x  = sweep_lbl_pos == "Right" ? rr_extend + 15 : 0
cisd_lbl_x   = cisd_lbl_pos  == "Right" ? rr_extend      : 0
rr_lbl_x     = rr_lbl_pos    == "Right" ? rr_extend      : 0

// ── AUTO COMBO FROM CHART TIMEFRAME ──────────────────────────────────────────
// 1H → 1D/1H | 15M → 4H/15M | 5M → 1H/5M | 3M → 30M/3M | other → inactive
var int    q1_bars      = 0
var string sweep_tf_lbl = ""
var string cisd_tf_lbl  = ""
var string combo        = ""
var bool   tf_supported = false

if timeframe.period == "60"
    q1_bars      := 14
    sweep_tf_lbl := "1D"
    cisd_tf_lbl  := "1H"
    combo        := "1D/1H"
    tf_supported := true
else if timeframe.period == "15"
    q1_bars      := 4
    sweep_tf_lbl := "4H"
    cisd_tf_lbl  := "15M"
    combo        := "4H/15M"
    tf_supported := true
else if timeframe.period == "5"
    q1_bars      := 3
    sweep_tf_lbl := "1H"
    cisd_tf_lbl  := "5M"
    combo        := "1H/5M"
    tf_supported := true
else if timeframe.period == "3"
    q1_bars      := 3
    sweep_tf_lbl := "30M"
    cisd_tf_lbl  := "3M"
    combo        := "30M/3M"
    tf_supported := true

// Show watermark if TF not supported
if barstate.islast and not tf_supported
    label.new(bar_index, high, "Abhi's Fractal Sweep\nUse 1H / 15M / 5M / 3M chart", color=color.new(color.gray, 80), textcolor=color.gray, style=label.style_label_left, size=size.normal)

// ── HELPERS ───────────────────────────────────────────────────────────────────
is_rth() =>
    h = hour(time, "America/New_York")
    h >= 7 and h < 16

// ── ANCHOR CANDLE — pre-declared with literal TF strings ──────────────────────
// Pine v5 requires literal or consistent strings in request.security timeframe arg.
// All 4 TFs are pre-fetched; correct one selected by chart TF below.
ph_1D  = request.security(syminfo.tickerid, "1D",  high[1], lookahead=barmerge.lookahead_on)
pl_1D  = request.security(syminfo.tickerid, "1D",  low[1],  lookahead=barmerge.lookahead_on)
at_1D  = request.security(syminfo.tickerid, "1D",  time,    lookahead=barmerge.lookahead_on)
ph_240 = request.security(syminfo.tickerid, "240", high[1], lookahead=barmerge.lookahead_on)
pl_240 = request.security(syminfo.tickerid, "240", low[1],  lookahead=barmerge.lookahead_on)
at_240 = request.security(syminfo.tickerid, "240", time,    lookahead=barmerge.lookahead_on)
ph_60  = request.security(syminfo.tickerid, "60",  high[1], lookahead=barmerge.lookahead_on)
pl_60  = request.security(syminfo.tickerid, "60",  low[1],  lookahead=barmerge.lookahead_on)
at_60  = request.security(syminfo.tickerid, "60",  time,    lookahead=barmerge.lookahead_on)
ph_30  = request.security(syminfo.tickerid, "30",  high[1], lookahead=barmerge.lookahead_on)
pl_30  = request.security(syminfo.tickerid, "30",  low[1],  lookahead=barmerge.lookahead_on)
at_30  = request.security(syminfo.tickerid, "30",  time,    lookahead=barmerge.lookahead_on)

prior_high    = timeframe.period == "60" ? ph_1D : timeframe.period == "15" ? ph_240 : timeframe.period == "5" ? ph_60 : ph_30
prior_low     = timeframe.period == "60" ? pl_1D : timeframe.period == "15" ? pl_240 : timeframe.period == "5" ? pl_60 : pl_30
anchor_time   = timeframe.period == "60" ? at_1D : timeframe.period == "15" ? at_240 : timeframe.period == "5" ? at_60 : at_30
is_new_anchor = ta.change(anchor_time) != 0

// ── STATE ─────────────────────────────────────────────────────────────────────
var float anc_hi          = na
var float anc_lo          = na
var int   q1_elapsed      = 0
var bool  in_q1           = false
var bool  swept_long      = false
var bool  swept_short     = false
var float sweep_ext_long  = na
var float sweep_ext_short = na
var int   sweep_bar_long  = na
var int   sweep_bar_short = na
var bool  ret_long        = false
var bool  ret_short       = false
var bool  alerted_long    = false
var bool  alerted_short   = false
// drawing object refs for cleanup
var line  sweep_line_long   = na
var label sweep_lbl_long    = na
var line  sweep_line_short  = na
var label sweep_lbl_short   = na
var line  cisd_prev_long    = na
var line  cisd_prev_short   = na
var bool  prev_in_q1        = false
// bar index of the candle that made the prior TF high / low
var int   anc_hi_bar        = na
var int   anc_lo_bar        = na

// ── ANCHOR RESET ──────────────────────────────────────────────────────────────
if is_new_anchor and tf_supported
    anc_hi          := prior_high
    anc_lo          := prior_low
    q1_elapsed      := 0
    in_q1           := true
    swept_long      := false
    swept_short     := false
    sweep_ext_long  := na
    sweep_ext_short := na
    sweep_bar_long  := na
    sweep_bar_short := na
    ret_long        := false
    ret_short       := false
    alerted_long    := false
    alerted_short   := false
    // find which bar made the prior TF high and low
    anc_hi_bar := bar_index - 1
    anc_lo_bar := bar_index - 1
    for k = 1 to 30
        if high[k] == prior_high
            anc_hi_bar := bar_index - k
            break
    for k = 1 to 30
        if low[k] == prior_low
            anc_lo_bar := bar_index - k
            break
    // clean up any leftover drawings from previous Q1
    line.delete(sweep_line_long)
    sweep_line_long  := na
    label.delete(sweep_lbl_long)
    sweep_lbl_long   := na
    line.delete(sweep_line_short)
    sweep_line_short := na
    label.delete(sweep_lbl_short)
    sweep_lbl_short  := na
    line.delete(cisd_prev_long)
    cisd_prev_long   := na
    line.delete(cisd_prev_short)
    cisd_prev_short  := na

// ── Q1 COUNTER ────────────────────────────────────────────────────────────────
if in_q1
    q1_elapsed += 1
    if q1_elapsed >= q1_bars
        in_q1 := false

q1_just_ended = prev_in_q1 and not in_q1
prev_in_q1   := in_q1

if q1_just_ended
    // remove all sweep & preview drawings AND reset state if CISD never fired
    if not alerted_long
        line.delete(sweep_line_long)
        sweep_line_long := na
        label.delete(sweep_lbl_long)
        sweep_lbl_long  := na
        line.delete(cisd_prev_long)
        cisd_prev_long  := na
        swept_long      := false
        ret_long        := false
        sweep_ext_long  := na
        sweep_bar_long  := na
    if not alerted_short
        line.delete(sweep_line_short)
        sweep_line_short := na
        label.delete(sweep_lbl_short)
        sweep_lbl_short  := na
        line.delete(cisd_prev_short)
        cisd_prev_short  := na
        swept_short      := false
        ret_short        := false
        sweep_ext_short  := na
        sweep_bar_short  := na

// ── PHASE 1: SWEEP ────────────────────────────────────────────────────────────
// sweep_ext_long/short = wick extreme (SL level)
// sweep line drawn at anc_lo/anc_hi (prior candle boundary — the swept level)
if tf_supported and in_q1 and not na(anc_hi) and not na(anc_lo)
    ref_range = anc_hi - anc_lo
    if ref_range > 0
        if not swept_long
            ext = anc_lo - low
            if low < anc_lo and ext / ref_range >= sweep_min and ext / ref_range <= sweep_max
                swept_long      := true
                sweep_ext_long  := low
                sweep_bar_long  := bar_index
                sweep_x_long    = sweep_lbl_pos == "Right" ? bar_index + rr_extend : anc_lo_bar
                sweep_line_long := line.new(anc_lo_bar, anc_lo, bar_index + rr_extend, anc_lo, color=color.red, width=2, style=sweep_lstyle)
                sweep_lbl_long  := label.new(sweep_x_long, anc_lo, sweep_text + " " + sweep_tf_lbl, color=color.new(color.red, 100), textcolor=color.red, style=sweep_lbl_style, size=size.small)
        if not swept_short
            ext = high - anc_hi
            if high > anc_hi and ext / ref_range >= sweep_min and ext / ref_range <= sweep_max
                swept_short      := true
                sweep_ext_short  := high
                sweep_bar_short  := bar_index
                sweep_x_short    = sweep_lbl_pos == "Right" ? bar_index + rr_extend : anc_hi_bar
                sweep_line_short := line.new(anc_hi_bar, anc_hi, bar_index + rr_extend, anc_hi, color=color.red, width=2, style=sweep_lstyle)
                sweep_lbl_short  := label.new(sweep_x_short, anc_hi, sweep_text + " " + sweep_tf_lbl, color=color.new(color.red, 100), textcolor=color.red, style=sweep_lbl_style, size=size.small)

// Track swing extreme — SL = lowest low / highest high from sweep until fire
if tf_supported
    if swept_long and not alerted_long and not na(sweep_ext_long) and low < sweep_ext_long
        sweep_ext_long := low
        sweep_bar_long := bar_index
    if swept_short and not alerted_short and not na(sweep_ext_short) and high > sweep_ext_short
        sweep_ext_short := high
        sweep_bar_short := bar_index

// ── PHASE 2: RETURN TO RANGE ──────────────────────────────────────────────────
if in_q1
    if swept_long  and not ret_long  and close >= anc_lo
        ret_long  := true
    if swept_short and not ret_short and close <= anc_hi
        ret_short := true

// ── PHASE 3: CISD ─────────────────────────────────────────────────────────────
f_cisd_long() =>
    cisd_lvl  = float(na)
    run_start = 0
    for k = 1 to cisd_lookback
        if close[k] < open[k]
            run_start := k
            break
    if run_start > 0
        for k = run_start + 1 to run_start + cisd_lookback
            if k < bar_index
                if close[k] < open[k] or close[k] == open[k]
                    run_start := k
                else
                    break
        cisd_lvl := open[run_start]
    [not na(cisd_lvl) and close > cisd_lvl, cisd_lvl, run_start]

f_cisd_short() =>
    cisd_lvl  = float(na)
    run_start = 0
    for k = 1 to cisd_lookback
        if close[k] > open[k]
            run_start := k
            break
    if run_start > 0
        for k = run_start + 1 to run_start + cisd_lookback
            if k < bar_index
                if close[k] > open[k] or close[k] == open[k]
                    run_start := k
                else
                    break
        cisd_lvl := open[run_start]
    [not na(cisd_lvl) and close < cisd_lvl, cisd_lvl, run_start]

[cisd_long_fired,  cisd_long_lvl,  cisd_long_off]  = f_cisd_long()
[cisd_short_fired, cisd_short_lvl, cisd_short_off] = f_cisd_short()

// ── CISD PREVIEW — live expected CISD level while in Q1 ──────────────────────
// Draws a dashed line at the current CISD level (open of the opposing run) while
// waiting for confirmation. Deleted once CISD fires or Q1 ends without it.
if tf_supported and in_q1
    if swept_long and ret_long and not alerted_long and not na(cisd_long_lvl)
        line.delete(cisd_prev_long)
        cisd_prev_long := line.new(bar_index - cisd_lookback, cisd_long_lvl, bar_index + 5, cisd_long_lvl, color=color.new(color.blue, 50), width=1, style=line.style_dashed)
    else
        line.delete(cisd_prev_long)
        cisd_prev_long := na
    if swept_short and ret_short and not alerted_short and not na(cisd_short_lvl)
        line.delete(cisd_prev_short)
        cisd_prev_short := line.new(bar_index - cisd_lookback, cisd_short_lvl, bar_index + 5, cisd_short_lvl, color=color.new(color.blue, 50), width=1, style=line.style_dashed)
    else
        line.delete(cisd_prev_short)
        cisd_prev_short := na

// ── VALIDITY ──────────────────────────────────────────────────────────────────
long_risk  = not na(sweep_ext_long)  ? math.abs(close - sweep_ext_long)  : 0.0
short_risk = not na(sweep_ext_short) ? math.abs(close - sweep_ext_short) : 0.0
long_valid  = tf_supported and ret_long  and cisd_long_fired  and not alerted_long  and long_risk  >= min_risk
short_valid = tf_supported and ret_short and cisd_short_fired and not alerted_short and short_risk >= min_risk
if rth_only
    long_valid  := long_valid  and is_rth()
    short_valid := short_valid and is_rth()

// ── FIRE: LONG ────────────────────────────────────────────────────────────────
if long_valid
    alerted_long := true
    line.delete(cisd_prev_long)
    cisd_prev_long := na
    entry = close
    sl    = sweep_ext_long
    risk  = entry - sl
    tp    = entry + risk * rr_ratio
    r_end = bar_index + rr_extend
    cisd_bar = bar_index - cisd_long_off
    line.new(cisd_bar, cisd_long_lvl, r_end, cisd_long_lvl, color=color.blue, width=2, style=cisd_lstyle)
    cisd_x = cisd_lbl_pos == "Right" ? bar_index + rr_extend : cisd_bar
    label.new(cisd_x, cisd_long_lvl, cisd_text + " " + cisd_tf_lbl, color=color.new(color.blue, 100), textcolor=color.blue, style=cisd_lbl_style, size=size.small)
    // redraw sweep line from anchor candle to r_end (may have been deleted by Q1 cleanup)
    if not na(sweep_line_long)
        line.delete(sweep_line_long)
    if not na(sweep_lbl_long)
        label.delete(sweep_lbl_long)
    line.new(anc_lo_bar, anc_lo, r_end, anc_lo, color=color.red, width=2, style=sweep_lstyle)
    sweep_x = sweep_lbl_pos == "Right" ? r_end : anc_lo_bar
    label.new(sweep_x, anc_lo, sweep_text + " " + sweep_tf_lbl, color=color.new(color.red, 100), textcolor=color.red, style=sweep_lbl_style, size=size.small)
    sl_anchor = not na(sweep_bar_long) ? sweep_bar_long : bar_index
    line.new(sl_anchor, sl, r_end, sl, color=color.red, width=2, style=sweep_lstyle)
    box.new(bar_index, entry, r_end, sl,  border_color=rr_risk_border, bgcolor=rr_risk_col)
    box.new(bar_index, tp,    r_end, entry, border_color=rr_rew_border,  bgcolor=rr_rew_col)
    line.new(bar_index, entry, r_end, entry, color=rr_entry_col, width=1, style=line.style_solid)
    label.new(bar_index + rr_lbl_x, tp,    "TP  +" + str.tostring(risk * rr_ratio, "#.##") + " pts  " + str.tostring(rr_ratio, "#.#") + "R", color=rr_lbl_tp_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny)
    label.new(bar_index + rr_lbl_x, entry, "Entry  " + str.tostring(entry, "#.##"), color=rr_lbl_en_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny)
    label.new(bar_index + rr_lbl_x, sl,    "SL  -" + str.tostring(risk, "#.##") + " pts", color=rr_lbl_sl_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny)
    alert("LONG " + syminfo.ticker + " | Entry " + str.tostring(entry, "#.##") + " | SL " + str.tostring(sl, "#.##") + " | TP " + str.tostring(tp, "#.##") + " | Risk " + str.tostring(long_risk, "#.#") + " pts | " + combo, alert.freq_once_per_bar_close)

// ── FIRE: SHORT ───────────────────────────────────────────────────────────────
if short_valid
    alerted_short := true
    line.delete(cisd_prev_short)
    cisd_prev_short := na
    entry = close
    sl    = sweep_ext_short
    risk  = sl - entry
    tp    = entry - risk * rr_ratio
    r_end = bar_index + rr_extend
    cisd_bar = bar_index - cisd_short_off
    line.new(cisd_bar, cisd_short_lvl, r_end, cisd_short_lvl, color=color.blue, width=2, style=cisd_lstyle)
    cisd_x = cisd_lbl_pos == "Right" ? bar_index + rr_extend : cisd_bar
    label.new(cisd_x, cisd_short_lvl, cisd_text + " " + cisd_tf_lbl, color=color.new(color.blue, 100), textcolor=color.blue, style=cisd_lbl_style, size=size.small)
    // redraw sweep line from anchor candle to r_end (may have been deleted by Q1 cleanup)
    if not na(sweep_line_short)
        line.delete(sweep_line_short)
    if not na(sweep_lbl_short)
        label.delete(sweep_lbl_short)
    line.new(anc_hi_bar, anc_hi, r_end, anc_hi, color=color.red, width=2, style=sweep_lstyle)
    sweep_x = sweep_lbl_pos == "Right" ? r_end : anc_hi_bar
    label.new(sweep_x, anc_hi, sweep_text + " " + sweep_tf_lbl, color=color.new(color.red, 100), textcolor=color.red, style=sweep_lbl_style, size=size.small)
    sl_anchor = not na(sweep_bar_short) ? sweep_bar_short : bar_index
    line.new(sl_anchor, sl, r_end, sl, color=color.red, width=2, style=sweep_lstyle)
    box.new(bar_index, sl,    r_end, entry, border_color=rr_risk_border, bgcolor=rr_risk_col)
    box.new(bar_index, entry, r_end, tp,    border_color=rr_rew_border,  bgcolor=rr_rew_col)
    line.new(bar_index, entry, r_end, entry, color=rr_entry_col, width=1, style=line.style_solid)
    label.new(bar_index + rr_lbl_x, tp,    "TP  +" + str.tostring(risk * rr_ratio, "#.##") + " pts  " + str.tostring(rr_ratio, "#.#") + "R", color=rr_lbl_tp_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny)
    label.new(bar_index + rr_lbl_x, entry, "Entry  " + str.tostring(entry, "#.##"), color=rr_lbl_en_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny)
    label.new(bar_index + rr_lbl_x, sl,    "SL  -" + str.tostring(risk, "#.##") + " pts", color=rr_lbl_sl_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny)
    alert("SHORT " + syminfo.ticker + " | Entry " + str.tostring(entry, "#.##") + " | SL " + str.tostring(sl, "#.##") + " | TP " + str.tostring(tp, "#.##") + " | Risk " + str.tostring(short_risk, "#.#") + " pts | " + combo, alert.freq_once_per_bar_close)
