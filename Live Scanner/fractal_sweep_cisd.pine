// Statistic.ally — Fractal Sweep CISD Indicator
// https://github.com/abhinaynatraj/TradingHub
//@version=5
indicator("Abhi's Fractal Sweep", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ── INPUTS ────────────────────────────────────────────────────────────────────
var string G2 = "Filters"
sweep_max     = input.float(50.0, "Sweep Max %", group=G2, step=0.5) / 100
min_risk      = input.float(3.0,   "Min Risk (pts)", group=G2)
max_risk      = input.float(112.5, "Max Risk (pts)", group=G2, tooltip="MNQ: $225 risk ÷ $2.00/pt = 112.5 pts")
min_range     = input.float(12.0,  "Min Prior Range (pts)", group=G2, tooltip="Reject setups where prior candle range < this. Backtest: 4H=30, 1H=12, 30M=8")
cisd_lookback = input.int(100,    "CISD Lookback Bars", group=G2, tooltip="Max bars to scan for CISD delivery run. 100 = effectively unlimited.")

var string G10 = "SMT Divergence"
show_smt      = input.bool(true,    "Show SMT Labels", group=G10, tooltip="Check ES for divergence when NQ sweeps")
smt_symbol    = input.string("ES1!", "ES Symbol", group=G10, tooltip="Continuous ES contract for SMT comparison")

var string G8 = "Display"
show_debug    = input.bool(false, "Show Debug Labels", group=G8)
max_setups    = input.int(1, "Max Setups to Show", group=G8, minval=1, maxval=20, tooltip="Only the N most recent fired setups are kept; older ones are removed")

var string G9 = "Split Profile"
use_split       = input.bool(false,   "Use Split Profile", group=G9, tooltip="TP1 @ PTQ%, SL = min(struct, MAE p90%). Values from backtest dashboard.")
split_ptq_pct   = input.float(0.42,   "TP1 PTQ %", group=G9, step=0.01, tooltip="PTQ level from MFE study (e.g. 0.42 = 0.42% of entry price)")
split_p50_pct   = input.float(1.12,   "TP2 p50 MFE %", group=G9, step=0.01, tooltip="Median winner MFE — runner target (10% position)")
split_mae_pct   = input.float(0.36,   "SL MAE p90 %", group=G9, step=0.01, tooltip="MAE p90 of winners — SL cap. SL = min(sweep extreme, entry × MAE p90%)")
split_tp1_size  = input.float(90.0,   "TP1 Exit %", group=G9, step=5.0, minval=50, maxval=100, tooltip="% of position to exit at TP1")

var string G3 = "R:R Box"
rr_extend      = input.int(20,    "Box Width (bars)", group=G3, minval=5, maxval=100)
rr_ratio       = input.float(1.0, "R:R Target", group=G3, step=0.5, minval=0.5, tooltip="e.g. 2 = TP at 2R. Ignored when Split Profile is on.")
rr_risk_col    = input.color(color.new(color.red,  85), "Risk Zone Fill",    group=G3)
rr_risk_border = input.color(color.new(color.red,  40), "Risk Zone Border",  group=G3)
rr_rew_col     = input.color(color.new(color.teal, 85), "Reward Zone Fill",  group=G3)
rr_rew_border  = input.color(color.new(color.teal, 40), "Reward Zone Border", group=G3)
rr_entry_col   = input.color(color.white,               "Entry Line Color",  group=G3)

var string G4 = "Sweep Line"
sweep_style_inp = input.string("Dotted",   "Line Style",     options=["Dotted", "Dashed", "Solid"], group=G4)
sweep_text      = input.string("Sweep of", "Label Text",     group=G4, tooltip="TF is appended automatically")
sweep_lbl_pos   = input.string("Right",    "Label Position", options=["Left", "Right"], group=G4)

var string G5 = "CISD Line"
cisd_style_inp  = input.string("Dotted", "Line Style",     options=["Dotted", "Dashed", "Solid"], group=G5)
cisd_text       = input.string("CISD",   "Label Text",     group=G5, tooltip="TF is appended automatically")
cisd_lbl_pos    = input.string("Right",  "Label Position", options=["Left", "Right"], group=G5)

var string G7 = "T-Spot Zone"
show_tspot      = input.bool(false,       "Show T-Spot Zone",     group=G7)
tspot_transp    = input.int(85,           "Zone Transparency",    group=G7, minval=0, maxval=100)
show_c_labels   = input.bool(true,        "Show C2/C3 Labels",   group=G7)
show_tspot_type = input.bool(true,        "Show T-Spot Type",    group=G7)
show_proj       = input.bool(true,        "Show CISD Projections", group=G7)
proj_levels_str = input.string("0.5,1.0,1.5,2.0", "Projection Levels", group=G7, tooltip="Comma-separated multiples of CISD series range")
proj_color      = input.color(color.gray, "Projection Color",    group=G7)

var string G6 = "R:R Labels"
rr_lbl_pos    = input.string("Right",                        "Label Position", options=["Left", "Right"], group=G6)
rr_lbl_tp_col = input.color(color.new(color.teal, 20), "TP Label Color",    group=G6)
rr_lbl_sl_col = input.color(color.new(color.red,  20), "SL Label Color",    group=G6)
rr_lbl_en_col = input.color(color.new(color.gray, 60), "Entry Label Color", group=G6)

// ── STYLE HELPERS ─────────────────────────────────────────────────────────────
// "Right" → anchor at END of line, text flows right → style_label_left
// "Left"  → anchor at START of line, text flows left → style_label_right
sweep_lstyle    = sweep_style_inp == "Dashed" ? line.style_dashed : sweep_style_inp == "Solid" ? line.style_solid : line.style_dotted
cisd_lstyle     = cisd_style_inp  == "Dashed" ? line.style_dashed : cisd_style_inp  == "Solid" ? line.style_solid : line.style_dotted
sweep_lbl_style = sweep_lbl_pos == "Right" ? label.style_label_left  : label.style_label_right
cisd_lbl_style  = cisd_lbl_pos  == "Right" ? label.style_label_left  : label.style_label_right
rr_lbl_style    = rr_lbl_pos    == "Right" ? label.style_label_left  : label.style_label_right
// x-position offset: Right = end of line, Left = start of line
sweep_lbl_x  = sweep_lbl_pos == "Right" ? rr_extend + 15 : 0
cisd_lbl_x   = cisd_lbl_pos  == "Right" ? rr_extend      : 0
rr_lbl_x     = rr_lbl_pos    == "Right" ? rr_extend      : 0

// ── AUTO COMBO FROM CHART TIMEFRAME ──────────────────────────────────────────
// 1H → 1D/1H | 15M → 4H/15M | 5M → 1H/5M | 3M → 30M/3M | other → inactive
var int    q1_bars      = 0
// ret_bars removed — no window deadline; CISD can form anytime after sweep
var string sweep_tf_lbl = ""
var string cisd_tf_lbl  = ""
var string combo        = ""
var bool   tf_supported = false

if timeframe.period == "60"
    q1_bars      := 6
    // ret_bars removed
    sweep_tf_lbl := "1D"
    cisd_tf_lbl  := "1H"
    combo        := "1D/1H"
    tf_supported := true
else if timeframe.period == "15"
    q1_bars      := 4
    // ret_bars removed
    sweep_tf_lbl := "4H"
    cisd_tf_lbl  := "15M"
    combo        := "4H/15M"
    tf_supported := true
else if timeframe.period == "5"
    q1_bars      := 3
    // ret_bars removed
    sweep_tf_lbl := "1H"
    cisd_tf_lbl  := "5M"
    combo        := "1H/5M"
    tf_supported := true
else if timeframe.period == "3"
    q1_bars      := 5
    // ret_bars removed
    sweep_tf_lbl := "30M"
    cisd_tf_lbl  := "3M"
    combo        := "30M/3M"
    tf_supported := true

// ── HELPERS ───────────────────────────────────────────────────────────────────
// Logarithmic midpoint — weights toward the dominant wick (same as TTFM)
f_log_mid(float _h, float _l, float _o, float _c) =>
    log_h = math.log(_h)
    log_l = math.log(_l)
    log_o = math.log(_o)
    log_c = math.log(_c)
    body_sz = math.abs(log_c - log_o)
    upper_w = log_h - math.max(log_o, log_c)
    lower_w = math.min(log_o, log_c) - log_l
    log_mid = math.max(upper_w, lower_w) > body_sz ? (upper_w > lower_w ? log_h - upper_w / 2 : log_l + lower_w / 2) : (log_h + log_l) / 2
    math.exp(log_mid)

// ── ANCHOR CANDLE — pre-declared with literal TF strings ──────────────────────
// Pine v5 requires literal or consistent strings in request.security timeframe arg.
// All 4 TFs are pre-fetched; correct one selected by chart TF below.
ph_1D  = request.security(syminfo.tickerid, "1D",  high[1], lookahead=barmerge.lookahead_on)
pl_1D  = request.security(syminfo.tickerid, "1D",  low[1],  lookahead=barmerge.lookahead_on)
pc_1D  = request.security(syminfo.tickerid, "1D",  close[1], lookahead=barmerge.lookahead_on)
at_1D  = request.security(syminfo.tickerid, "1D",  time,    lookahead=barmerge.lookahead_on)
ph2_1D = request.security(syminfo.tickerid, "1D",  high[2], lookahead=barmerge.lookahead_on)
pl2_1D = request.security(syminfo.tickerid, "1D",  low[2],  lookahead=barmerge.lookahead_on)
ph_240 = request.security(syminfo.tickerid, "240", high[1], lookahead=barmerge.lookahead_on)
pl_240 = request.security(syminfo.tickerid, "240", low[1],  lookahead=barmerge.lookahead_on)
pc_240 = request.security(syminfo.tickerid, "240", close[1], lookahead=barmerge.lookahead_on)
at_240 = request.security(syminfo.tickerid, "240", time,    lookahead=barmerge.lookahead_on)
ph2_240 = request.security(syminfo.tickerid, "240", high[2], lookahead=barmerge.lookahead_on)
pl2_240 = request.security(syminfo.tickerid, "240", low[2],  lookahead=barmerge.lookahead_on)
ph_60  = request.security(syminfo.tickerid, "60",  high[1], lookahead=barmerge.lookahead_on)
pl_60  = request.security(syminfo.tickerid, "60",  low[1],  lookahead=barmerge.lookahead_on)
pc_60  = request.security(syminfo.tickerid, "60",  close[1], lookahead=barmerge.lookahead_on)
at_60  = request.security(syminfo.tickerid, "60",  time,    lookahead=barmerge.lookahead_on)
ph2_60 = request.security(syminfo.tickerid, "60",  high[2], lookahead=barmerge.lookahead_on)
pl2_60 = request.security(syminfo.tickerid, "60",  low[2],  lookahead=barmerge.lookahead_on)
ph_30  = request.security(syminfo.tickerid, "30",  high[1], lookahead=barmerge.lookahead_on)
pl_30  = request.security(syminfo.tickerid, "30",  low[1],  lookahead=barmerge.lookahead_on)
pc_30  = request.security(syminfo.tickerid, "30",  close[1], lookahead=barmerge.lookahead_on)
at_30  = request.security(syminfo.tickerid, "30",  time,    lookahead=barmerge.lookahead_on)
ph2_30 = request.security(syminfo.tickerid, "30",  high[2], lookahead=barmerge.lookahead_on)
pl2_30 = request.security(syminfo.tickerid, "30",  low[2],  lookahead=barmerge.lookahead_on)

// ── ES ANCHOR CANDLE — for SMT divergence check ─────────────────────────────
// ES prior HTF high/low + ES LTF high/low (to check if ES swept at same time as NQ)
es_ph_1D  = request.security(smt_symbol, "1D",  high[1], lookahead=barmerge.lookahead_on)
es_pl_1D  = request.security(smt_symbol, "1D",  low[1],  lookahead=barmerge.lookahead_on)
es_ph_240 = request.security(smt_symbol, "240", high[1], lookahead=barmerge.lookahead_on)
es_pl_240 = request.security(smt_symbol, "240", low[1],  lookahead=barmerge.lookahead_on)
es_ph_60  = request.security(smt_symbol, "60",  high[1], lookahead=barmerge.lookahead_on)
es_pl_60  = request.security(smt_symbol, "60",  low[1],  lookahead=barmerge.lookahead_on)
es_ph_30  = request.security(smt_symbol, "30",  high[1], lookahead=barmerge.lookahead_on)
es_pl_30  = request.security(smt_symbol, "30",  low[1],  lookahead=barmerge.lookahead_on)
// ES LTF bar data — high/low on the same timeframe as the chart
es_ltf_high = request.security(smt_symbol, timeframe.period, high)
es_ltf_low  = request.security(smt_symbol, timeframe.period, low)

es_prior_high = timeframe.period == "60" ? es_ph_1D : timeframe.period == "15" ? es_ph_240 : timeframe.period == "5" ? es_ph_60 : es_ph_30
es_prior_low  = timeframe.period == "60" ? es_pl_1D : timeframe.period == "15" ? es_pl_240 : timeframe.period == "5" ? es_pl_60 : es_pl_30

prior_high    = timeframe.period == "60" ? ph_1D : timeframe.period == "15" ? ph_240 : timeframe.period == "5" ? ph_60 : ph_30
prior_low     = timeframe.period == "60" ? pl_1D : timeframe.period == "15" ? pl_240 : timeframe.period == "5" ? pl_60 : pl_30
prior_close   = timeframe.period == "60" ? pc_1D : timeframe.period == "15" ? pc_240 : timeframe.period == "5" ? pc_60 : pc_30
prev2_high    = timeframe.period == "60" ? ph2_1D : timeframe.period == "15" ? ph2_240 : timeframe.period == "5" ? ph2_60 : ph2_30
prev2_low     = timeframe.period == "60" ? pl2_1D : timeframe.period == "15" ? pl2_240 : timeframe.period == "5" ? pl2_60 : pl2_30
anchor_time   = timeframe.period == "60" ? at_1D : timeframe.period == "15" ? at_240 : timeframe.period == "5" ? at_60 : at_30
is_new_anchor = ta.change(anchor_time) != 0

// ── STATE ─────────────────────────────────────────────────────────────────────
var float anc_hi          = na
var float anc_lo          = na
var int   q1_elapsed      = 0
var bool  in_q1           = false
var bool  swept_long      = false
var bool  swept_short     = false
var float sweep_ext_long  = na
var float sweep_ext_short = na
var int   sweep_bar_long  = na
var int   sweep_bar_short = na
var bool  ret_long        = false
var bool  ret_short       = false
var bool  alerted_long    = false
var bool  alerted_short   = false
// Q1 quality flag — true if sweep was detected within Q1 window
var bool  q1_sweep_long   = false
var bool  q1_sweep_short  = false
// drawing object refs for cleanup
var line  sweep_line_long   = na
var label sweep_lbl_long    = na
var line  sweep_line_short  = na
var label sweep_lbl_short   = na
var line  cisd_prev_long    = na
var line  cisd_prev_short   = na
var label cisd_prev_lbl_long  = na
var label cisd_prev_lbl_short = na
// bar index of the candle that made the prior TF high / low
var int   anc_hi_bar        = na
var int   anc_lo_bar        = na
// sweep candle data for T-Spot zone
var float sweep_logmid_long  = na
var float sweep_logmid_short = na
var float sweep_close_long   = na
var float sweep_close_short  = na
var float sweep_pct_long     = na
var float sweep_pct_short    = na
// bar index where return-to-range happened (CISD scans backward from here)
var int   ret_bar_long       = na
var int   ret_bar_short      = na
// SMT divergence — true if ES did NOT sweep its corresponding level when NQ swept
var bool  smt_long           = false
var bool  smt_short          = false
// arrays to track fired setup drawings for cleanup when exceeding max_setups
var fired_lines  = array.new_line()
var fired_labels = array.new_label()
var fired_boxes  = array.new_box()
// per-setup drawing counts: [nLines, nLabels, nBoxes] for each setup
var setup_line_counts  = array.new_int()
var setup_label_counts = array.new_int()
var setup_box_counts   = array.new_int()
// snapshot sizes before registering a new setup's drawings
var int _snap_lines  = 0
var int _snap_labels = 0
var int _snap_boxes  = 0

// helper: register a fired drawing for later cleanup
f_reg_line(line l)   => array.push(fired_lines, l)
f_reg_label(label l) => array.push(fired_labels, l)
f_reg_box(box b)     => array.push(fired_boxes, b)

// ── ANCHOR RESET ──────────────────────────────────────────────────────────────
if is_new_anchor and tf_supported
    // Capture fired state BEFORE resetting — used to preserve fired drawings
    _was_alerted_long  = alerted_long
    _was_alerted_short = alerted_short
    anc_hi          := prior_high
    anc_lo          := prior_low
    q1_elapsed      := 0
    in_q1           := true
    swept_long      := false
    swept_short     := false
    sweep_ext_long  := na
    sweep_ext_short := na
    sweep_bar_long   := na
    sweep_bar_short  := na
    sweep_logmid_long  := na
    sweep_logmid_short := na
    sweep_close_long   := na
    sweep_close_short  := na
    sweep_pct_long     := na
    sweep_pct_short    := na
    ret_bar_long       := na
    ret_bar_short      := na
    smt_long        := false
    smt_short       := false
    ret_long        := false
    ret_short       := false
    alerted_long    := false
    alerted_short   := false
    q1_sweep_long   := false
    q1_sweep_short  := false
    // find the FIRST (earliest) LTF bar within the prior HTF period that reached the high/low
    // Scan from newest (k=1) outward. Track the last match seen. Stop when we leave the period.
    // This way we find the earliest match within the prior period, not from older periods.
    _tol = syminfo.mintick * 2
    _htf_bars = timeframe.period == "60" ? 24 : timeframe.period == "15" ? 16 : timeframe.period == "5" ? 12 : 10
    anc_hi_bar := bar_index - 1
    anc_lo_bar := bar_index - 1
    // Scan newest to oldest: each match overwrites with an older bar.
    // At the end, anc_hi_bar/anc_lo_bar = earliest match within the scan range.
    for k = 1 to _htf_bars
        if k >= bar_index
            break
        if high[k] >= anc_hi - _tol
            anc_hi_bar := bar_index - k
    for k = 1 to _htf_bars
        if k >= bar_index
            break
        if low[k] <= anc_lo + _tol
            anc_lo_bar := bar_index - k
    // ── Pre-seed: did the prior candle itself sweep beyond the prev-prev range? ─
    // If the just-closed HTF candle swept above prev2_high and closed back below,
    // that IS a valid sweep+return — pre-seed state so only CISD is needed.
    if not na(prev2_high) and not na(prev2_low)
        pp_range = prev2_high - prev2_low
        if pp_range >= min_range
            // SHORT pre-seed: prior candle swept above prev-prev high, closed back below
            if prior_high > prev2_high and prior_close <= prev2_high
                ext_s = prior_high - prev2_high
                if ext_s / pp_range <= sweep_max
                    swept_short      := true
                    q1_sweep_short   := true
                    sweep_ext_short  := prior_high
                    sweep_bar_short  := bar_index - 1
                    sweep_pct_short  := ext_s / pp_range
                    ret_short        := true
                    ret_bar_short    := bar_index - 1
                    // override anc_hi/lo to the prev-prev candle (the one that was swept)
                    anc_hi := prev2_high
                    anc_lo := prev2_low
                    // re-search for anchor bars in prev-prev period (wider range)
                    for k2 = _htf_bars * 2 to 1
                        if high[k2] >= prev2_high - _tol
                            anc_hi_bar := bar_index - k2
                            break
                    for k2 = _htf_bars * 2 to 1
                        if low[k2] <= prev2_low + _tol
                            anc_lo_bar := bar_index - k2
                            break
            // LONG pre-seed: prior candle swept below prev-prev low, closed back above
            if prior_low < prev2_low and prior_close >= prev2_low
                ext_l = prev2_low - prior_low
                if ext_l / pp_range <= sweep_max
                    swept_long       := true
                    q1_sweep_long    := true
                    sweep_ext_long   := prior_low
                    sweep_bar_long   := bar_index - 1
                    sweep_pct_long   := ext_l / pp_range
                    ret_long         := true
                    ret_bar_long     := bar_index - 1
                    // override anc_hi/lo to the prev-prev candle (the one that was swept)
                    anc_hi := prev2_high
                    anc_lo := prev2_low
                    // re-search for anchor bars in prev-prev period (wider range)
                    for k2 = _htf_bars * 2 to 1
                        if high[k2] >= prev2_high - _tol
                            anc_hi_bar := bar_index - k2
                            break
                    for k2 = _htf_bars * 2 to 1
                        if low[k2] <= prev2_low + _tol
                            anc_lo_bar := bar_index - k2
                            break
    // clean up UNFIRED drawings only — fired setups keep their drawings
    if not _was_alerted_long
        line.delete(sweep_line_long)
        sweep_line_long  := na
        label.delete(sweep_lbl_long)
        sweep_lbl_long   := na
    else
        // detach refs so fired drawings aren't deleted later
        sweep_line_long  := na
        sweep_lbl_long   := na
    if not _was_alerted_short
        line.delete(sweep_line_short)
        sweep_line_short := na
        label.delete(sweep_lbl_short)
        sweep_lbl_short  := na
    else
        sweep_line_short := na
        sweep_lbl_short  := na
    // CISD previews are always pending — always clean up
    line.delete(cisd_prev_long)
    cisd_prev_long      := na
    label.delete(cisd_prev_lbl_long)
    cisd_prev_lbl_long  := na
    line.delete(cisd_prev_short)
    cisd_prev_short     := na
    label.delete(cisd_prev_lbl_short)
    cisd_prev_lbl_short := na
    // ── Draw sweep lines for pre-seeded setups ───────────────────────────────
    // Phase 1 detection only runs in Q1, so pre-seeded setups need lines drawn here.
    if swept_long
        ps_x = sweep_lbl_pos == "Right" ? bar_index + rr_extend : anc_lo_bar
        sweep_line_long := line.new(anc_lo_bar, anc_lo, bar_index + rr_extend, anc_lo, color=color.new(color.red, 25), width=1, style=line.style_dashed)
        sweep_lbl_long  := label.new(ps_x, anc_lo, sweep_text + " " + sweep_tf_lbl, color=color.new(color.red, 100), textcolor=color.new(color.red, 25), style=sweep_lbl_style, size=size.small)
    if swept_short
        ps_x = sweep_lbl_pos == "Right" ? bar_index + rr_extend : anc_hi_bar
        sweep_line_short := line.new(anc_hi_bar, anc_hi, bar_index + rr_extend, anc_hi, color=color.new(color.red, 25), width=1, style=line.style_dashed)
        sweep_lbl_short  := label.new(ps_x, anc_hi, sweep_text + " " + sweep_tf_lbl, color=color.new(color.red, 100), textcolor=color.new(color.red, 25), style=sweep_lbl_style, size=size.small)


// ── Q1 COUNTER ────────────────────────────────────────────────────────────────
q1_elapsed += 1
if q1_elapsed > q1_bars
    in_q1 := false

// No return window deadline — CISD can form anytime after sweep within the HTF period.
// Setups are cleaned up at anchor reset (next HTF candle), not by a bar-count timer.

// ── PHASE 1: SWEEP ────────────────────────────────────────────────────────────
// sweep_ext_long/short = wick extreme (SL level)
// sweep line drawn at anc_lo/anc_hi (prior candle boundary — the swept level)
// Detects sweeps throughout the entire HTF period; tags Q1 vs non-Q1 for color coding
sweep_line_col_long  = color.red
sweep_line_col_short = color.red
if tf_supported and not na(anc_hi) and not na(anc_lo)
    ref_range = anc_hi - anc_lo
    if ref_range >= min_range
        if not swept_long
            ext = anc_lo - low
            if low < anc_lo and ext / ref_range <= sweep_max
                swept_long       := true
                q1_sweep_long    := in_q1
                sweep_ext_long   := low
                sweep_bar_long   := bar_index
                sweep_logmid_long := f_log_mid(high, low, open, close)
                sweep_close_long  := close
                sweep_pct_long    := ref_range > 0 ? ext / ref_range : 0.0
                sweep_line_col_long := in_q1 ? color.red : color.orange
                sweep_x_long    = sweep_lbl_pos == "Right" ? bar_index + rr_extend : anc_lo_bar
                sweep_line_long := line.new(anc_lo_bar, anc_lo, bar_index + rr_extend, anc_lo, color=color.new(sweep_line_col_long, 25), width=1, style=line.style_dashed)
                sweep_lbl_long  := label.new(sweep_x_long, anc_lo, sweep_text + " " + sweep_tf_lbl + (in_q1 ? "" : " *"), color=color.new(sweep_line_col_long, 100), textcolor=color.new(sweep_line_col_long, 25), style=sweep_lbl_style, size=size.small)
                // Scan back over prior bars — earlier bars may have swept deeper
                for k = 1 to q1_elapsed - 1
                    if low[k] < anc_lo and low[k] < sweep_ext_long
                        sweep_ext_long := low[k]
                        sweep_bar_long := bar_index - k
                // SMT check: NQ swept low — did ES also sweep its prior low?
                // If ES did NOT sweep = SMT divergence (bullish confirmation)
                if show_smt and not na(es_prior_low)
                    smt_long := es_ltf_low > es_prior_low  // ES held above its prior low = divergence
        if not swept_short
            ext = high - anc_hi
            if high > anc_hi and ext / ref_range <= sweep_max
                swept_short       := true
                q1_sweep_short    := in_q1
                sweep_ext_short   := high
                sweep_bar_short   := bar_index
                sweep_logmid_short := f_log_mid(high, low, open, close)
                sweep_close_short  := close
                sweep_pct_short    := ref_range > 0 ? ext / ref_range : 0.0
                sweep_line_col_short := in_q1 ? color.red : color.orange
                sweep_x_short    = sweep_lbl_pos == "Right" ? bar_index + rr_extend : anc_hi_bar
                sweep_line_short := line.new(anc_hi_bar, anc_hi, bar_index + rr_extend, anc_hi, color=color.new(sweep_line_col_short, 25), width=1, style=line.style_dashed)
                sweep_lbl_short  := label.new(sweep_x_short, anc_hi, sweep_text + " " + sweep_tf_lbl + (in_q1 ? "" : " *"), color=color.new(sweep_line_col_short, 100), textcolor=color.new(sweep_line_col_short, 25), style=sweep_lbl_style, size=size.small)
                // Scan back over prior bars — earlier bars may have swept deeper
                for k = 1 to q1_elapsed - 1
                    if high[k] > anc_hi and high[k] > sweep_ext_short
                        sweep_ext_short := high[k]
                        sweep_bar_short := bar_index - k
                // SMT check: NQ swept high — did ES also sweep its prior high?
                // If ES did NOT sweep = SMT divergence (bearish confirmation)
                if show_smt and not na(es_prior_high)
                    smt_short := es_ltf_high < es_prior_high  // ES held below its prior high = divergence

// Sweep extreme is locked at detection time — matches backtest which computes
// the extreme once over the Q1 window. No continuous tracking after detection.

// ── PHASE 2: RETURN TO RANGE ──────────────────────────────────────────────────
// Return can happen anytime after sweep within the HTF period.
can_return = swept_long or swept_short
if can_return
    if swept_long  and not ret_long  and close >= anc_lo
        ret_long     := true
        ret_bar_long := bar_index
    if swept_short and not ret_short and close <= anc_hi
        ret_short     := true
        ret_bar_short := bar_index

// ── PHASE 3: CISD (matches backtest _find_cisd) ──────────────────────────────
// Scan backward from RETURN BAR to find the consecutive opposing delivery run.
// CISD level = open of the FIRST (earliest) candle in that run.
// Fire when current bar closes through that level.
//
// Algorithm (same as Python _find_cisd):
//   1. From ret_bar, scan backward — skip dojis, find nearest opposing candle
//   2. Continue backward through consecutive opposing candles (skip dojis)
//   3. Stop when a same-direction candle is hit
//   4. CISD level = open of the run_start (earliest opposing candle)

f_cisd_long(int ret_bar) =>
    // LONG: scan backward from ret_bar, skip dojis and bullish candles,
    // find nearest bearish candle, then walk back through consecutive bearish run.
    // CISD level = highest HIGH of the entire bearish run (TTFM series extreme).
    cisd_lvl = float(na)
    cisd_off = 0
    if not na(ret_bar)
        offset = bar_index - ret_bar
        nearest_k = 0
        for step = 1 to cisd_lookback * 4
            k = offset + step
            if k >= bar_index
                break
            if close[k] == open[k]
                continue
            if close[k] < open[k]
                nearest_k := k
                break
        if nearest_k > 0
            run_start_k = nearest_k
            series_high = high[nearest_k]
            for step2 = nearest_k + 1 to cisd_lookback * 4
                if step2 >= bar_index
                    break
                if close[step2] == open[step2]
                    continue
                if close[step2] < open[step2]
                    run_start_k := step2
                    series_high := math.max(series_high, high[step2])
                else
                    break
            cisd_lvl := series_high
            cisd_off := run_start_k
    [not na(cisd_lvl) and close > cisd_lvl, cisd_lvl, na(cisd_lvl) ? 0 : cisd_off]

f_cisd_short(int ret_bar) =>
    // SHORT: scan backward from ret_bar, skip dojis and bearish candles,
    // find nearest bullish candle, then walk back through consecutive bullish run.
    // CISD level = lowest LOW of the entire bullish run (TTFM series extreme).
    cisd_lvl = float(na)
    cisd_off = 0
    if not na(ret_bar)
        offset = bar_index - ret_bar
        nearest_k = 0
        for step = 1 to cisd_lookback * 4
            k = offset + step
            if k >= bar_index
                break
            if close[k] == open[k]
                continue
            if close[k] > open[k]
                nearest_k := k
                break
        if nearest_k > 0
            run_start_k = nearest_k
            series_low = low[nearest_k]
            for step2 = nearest_k + 1 to cisd_lookback * 4
                if step2 >= bar_index
                    break
                if close[step2] == open[step2]
                    continue
                if close[step2] > open[step2]
                    run_start_k := step2
                    series_low := math.min(series_low, low[step2])
                else
                    break
            cisd_lvl := series_low
            cisd_off := run_start_k
    [not na(cisd_lvl) and close < cisd_lvl, cisd_lvl, na(cisd_lvl) ? 0 : cisd_off]

// Fire + preview use the same scan
scan_bar_long  = not na(ret_bar_long)  ? ret_bar_long  : bar_index
scan_bar_short = not na(ret_bar_short) ? ret_bar_short : bar_index
[cisd_long_fired,  cisd_long_lvl,  cisd_long_off]  = f_cisd_long(scan_bar_long)
[cisd_short_fired, cisd_short_lvl, cisd_short_off] = f_cisd_short(scan_bar_short)

// ── CISD PREVIEW — shown immediately when sweep is detected, updated on return ─
if tf_supported
    if swept_long and not alerted_long and not na(cisd_long_lvl)
        line.delete(cisd_prev_long)
        label.delete(cisd_prev_lbl_long)
        cisd_prev_long     := line.new(bar_index - cisd_long_off, cisd_long_lvl, bar_index + 5, cisd_long_lvl, color=color.new(color.blue, 50), width=1, style=line.style_dashed)
        cisd_prev_lbl_long := label.new(bar_index + 5, cisd_long_lvl, cisd_text + " " + cisd_tf_lbl, color=color.new(color.blue, 100), textcolor=color.new(color.blue, 50), style=label.style_label_left, size=size.small)
    else if not swept_long or alerted_long
        line.delete(cisd_prev_long)
        label.delete(cisd_prev_lbl_long)
        cisd_prev_long     := na
        cisd_prev_lbl_long := na
    if swept_short and not alerted_short and not na(cisd_short_lvl)
        line.delete(cisd_prev_short)
        label.delete(cisd_prev_lbl_short)
        cisd_prev_short     := line.new(bar_index - cisd_short_off, cisd_short_lvl, bar_index + 5, cisd_short_lvl, color=color.new(color.blue, 50), width=1, style=line.style_dashed)
        cisd_prev_lbl_short := label.new(bar_index + 5, cisd_short_lvl, cisd_text + " " + cisd_tf_lbl, color=color.new(color.blue, 100), textcolor=color.new(color.blue, 50), style=label.style_label_left, size=size.small)
    else if not swept_short or alerted_short
        line.delete(cisd_prev_short)
        label.delete(cisd_prev_lbl_short)
        cisd_prev_short     := na
        cisd_prev_lbl_short := na

// ── VALIDITY ──────────────────────────────────────────────────────────────────
long_risk  = not na(sweep_ext_long)  ? math.abs(close - sweep_ext_long)  : 0.0
short_risk = not na(sweep_ext_short) ? math.abs(close - sweep_ext_short) : 0.0
long_base   = tf_supported and ret_long  and cisd_long_fired  and not alerted_long  and long_risk  >= min_risk
short_base  = tf_supported and ret_short and cisd_short_fired and not alerted_short and short_risk >= min_risk
long_valid  = long_base  and long_risk  <= max_risk
short_valid = short_base and short_risk <= max_risk
long_over   = long_base  and long_risk  > max_risk
short_over  = short_base and short_risk > max_risk

// ── DEBUG ─────────────────────────────────────────────────────────────────────
if show_debug and tf_supported and barstate.islast
    dbg = "Q1=" + str.tostring(q1_elapsed) + "/" + str.tostring(q1_bars)
         + "\nSWP_L=" + str.tostring(swept_long) + " RET_L=" + str.tostring(ret_long) + " ALT_L=" + str.tostring(alerted_long) + " Q1_L=" + str.tostring(q1_sweep_long)
         + "\nSWP_S=" + str.tostring(swept_short) + " RET_S=" + str.tostring(ret_short) + " ALT_S=" + str.tostring(alerted_short) + " Q1_S=" + str.tostring(q1_sweep_short)
         + "\nCISD_S_lvl=" + (not na(cisd_short_lvl) ? str.tostring(cisd_short_lvl, "#.##") : "na") + " fired=" + str.tostring(cisd_short_fired) + " off=" + str.tostring(cisd_short_off)
         + "\nCISD_L_lvl=" + (not na(cisd_long_lvl) ? str.tostring(cisd_long_lvl, "#.##") : "na") + " fired=" + str.tostring(cisd_long_fired) + " off=" + str.tostring(cisd_long_off)
         + "\nrisk_S=" + str.tostring(short_risk, "#.#") + " valid_S=" + str.tostring(short_valid)
         + "\nanc_hi=" + str.tostring(anc_hi, "#.##") + " anc_lo=" + str.tostring(anc_lo, "#.##")
         + "\nhi_bar_off=" + str.tostring(bar_index - anc_hi_bar) + " lo_bar_off=" + str.tostring(bar_index - anc_lo_bar)
    var label dbg_lbl = na
    label.delete(dbg_lbl)
    dbg_lbl := label.new(bar_index + 3, high, dbg, color=color.new(color.black, 20), textcolor=color.white, style=label.style_label_left, size=size.small, textalign=text.align_left)

// ── FIRE: LONG ────────────────────────────────────────────────────────────────
if long_valid
    alerted_long := true
    // Clean up own CISD preview
    line.delete(cisd_prev_long)
    cisd_prev_long := na
    label.delete(cisd_prev_lbl_long)
    cisd_prev_lbl_long := na
    // Clean up opposite side's pending drawings
    if not alerted_short
        line.delete(sweep_line_short)
        sweep_line_short := na
        label.delete(sweep_lbl_short)
        sweep_lbl_short := na
        line.delete(cisd_prev_short)
        cisd_prev_short := na
        label.delete(cisd_prev_lbl_short)
        cisd_prev_lbl_short := na
    _snap_lines  := array.size(fired_lines)
    _snap_labels := array.size(fired_labels)
    _snap_boxes  := array.size(fired_boxes)
    entry = close
    // Split profile: SL = min(sweep extreme, entry × MAE p90%)
    _struct_sl = sweep_ext_long
    sl = use_split ? math.max(_struct_sl, entry - entry * split_mae_pct / 100) : _struct_sl
    risk  = entry - sl
    // Split profile: TP1 = entry + entry × PTQ%, TP2 = entry + entry × p50%
    tp    = use_split ? entry + entry * split_ptq_pct / 100 : entry + risk * rr_ratio
    _tp2  = use_split ? entry + entry * split_p50_pct / 100 : float(na)
    _tp1_r = risk > 0 ? (tp - entry) / risk : 0.0
    r_end = bar_index + rr_extend
    // Non-Q1 uses amber/yellow palette
    _is_q1_l  = q1_sweep_long
    _risk_bg  = _is_q1_l ? rr_risk_col    : color.new(#dc2626, 90)
    _risk_br  = _is_q1_l ? rr_risk_border : color.new(#dc2626, 50)
    _rew_bg   = _is_q1_l ? rr_rew_col     : color.new(#eab308, 88)
    _rew_br   = _is_q1_l ? rr_rew_border  : color.new(#eab308, 40)
    _sl_col   = _is_q1_l ? color.red      : #dc2626
    _swp_col  = _is_q1_l ? color.red      : color.orange
    _cisd_col = _is_q1_l ? color.blue     : #eab308
    cisd_bar = bar_index - cisd_long_off
    f_reg_line(line.new(cisd_bar, cisd_long_lvl, r_end, cisd_long_lvl, color=_cisd_col, width=2, style=line.style_solid))
    cisd_x = cisd_lbl_pos == "Right" ? bar_index + rr_extend : cisd_bar
    f_reg_label(label.new(cisd_x, cisd_long_lvl, cisd_text + " " + cisd_tf_lbl + (_is_q1_l ? "" : " *"), color=color.new(_cisd_col, 100), textcolor=_cisd_col, style=cisd_lbl_style, size=size.small))
    if not na(sweep_line_long)
        line.delete(sweep_line_long)
    if not na(sweep_lbl_long)
        label.delete(sweep_lbl_long)
    f_reg_line(line.new(anc_lo_bar, anc_lo, r_end, anc_lo, color=_swp_col, width=2, style=line.style_solid))
    sweep_x = sweep_lbl_pos == "Right" ? r_end : anc_lo_bar
    f_reg_label(label.new(sweep_x, anc_lo, sweep_text + " " + sweep_tf_lbl + (_is_q1_l ? "" : " *"), color=color.new(_swp_col, 100), textcolor=_swp_col, style=sweep_lbl_style, size=size.small))
    sl_anchor = not na(sweep_bar_long) ? sweep_bar_long : bar_index
    f_reg_line(line.new(sl_anchor, sl, r_end, sl, color=_sl_col, width=2, style=sweep_lstyle))
    f_reg_box(box.new(bar_index, entry, r_end, sl,  border_color=_risk_br, bgcolor=_risk_bg))
    f_reg_box(box.new(bar_index, tp,    r_end, entry, border_color=_rew_br,  bgcolor=_rew_bg))
    f_reg_line(line.new(bar_index, entry, r_end, entry, color=rr_entry_col, width=1, style=line.style_solid))
    _tp_lbl = use_split ? "TP1  +" + str.tostring(tp - entry, "#.##") + " pts  " + str.tostring(_tp1_r, "#.#") + "R  (" + str.tostring(split_tp1_size, "#") + "%)" : "TP  +" + str.tostring(risk * rr_ratio, "#.##") + " pts  " + str.tostring(rr_ratio, "#.#") + "R"
    f_reg_label(label.new(bar_index + rr_lbl_x, tp, _tp_lbl, color=rr_lbl_tp_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, entry, "Entry  " + str.tostring(entry, "#.##"), color=rr_lbl_en_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, sl,    "SL  -" + str.tostring(risk, "#.##") + " pts", color=rr_lbl_sl_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    // TP2 runner target (split profile only)
    if use_split and not na(_tp2)
        f_reg_line(line.new(bar_index, _tp2, r_end, _tp2, color=color.new(color.purple, 30), width=1, style=line.style_dotted))
        f_reg_label(label.new(bar_index + rr_lbl_x, _tp2, "TP2  +" + str.tostring(_tp2 - entry, "#.##") + " pts  (runner " + str.tostring(100 - split_tp1_size, "#") + "%)", color=color.new(color.purple, 20), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    if show_tspot and not na(sweep_logmid_long) and not na(sweep_close_long)
        tspot_top  = math.max(sweep_logmid_long, sweep_close_long)
        tspot_bot  = math.min(sweep_logmid_long, sweep_close_long)
        sb = not na(sweep_bar_long) ? sweep_bar_long : bar_index
        f_reg_box(box.new(sb, tspot_top, r_end, tspot_bot, bgcolor=color.new(color.teal, tspot_transp), border_color=color.new(color.teal, tspot_transp + 5)))
        f_reg_line(line.new(sb, sweep_logmid_long, r_end, sweep_logmid_long, color=color.teal, width=1, style=line.style_dotted))
    if show_c_labels
        f_reg_label(label.new(anc_lo_bar, anc_lo, "C2", color=color.new(color.teal, 100), textcolor=color.teal, style=label.style_label_up, size=size.small))
        f_reg_label(label.new(bar_index, cisd_long_lvl, "C3", color=color.new(color.teal, 100), textcolor=color.teal, style=label.style_label_up, size=size.small))
    if show_tspot_type and not na(sweep_pct_long)
        ttype = sweep_pct_long < 0.30 ? "ProTrend" : sweep_pct_long < 0.80 ? "Normal" : "Expansive"
        f_reg_label(label.new(bar_index, tp, ttype + " LONG", color=color.new(color.teal, 100), textcolor=color.teal, style=label.style_label_down, size=size.tiny))
    if show_proj and cisd_long_off > 0
        series_hi = high[cisd_long_off]
        series_lo = low[cisd_long_off]
        for k = 1 to cisd_long_off - 1
            if close[cisd_long_off - k] < open[cisd_long_off - k]
                series_hi := math.max(series_hi, high[cisd_long_off - k])
                series_lo := math.min(series_lo, low[cisd_long_off - k])
            else
                break
        s_range = series_hi - series_lo
        if s_range > 0
            levels = str.split(proj_levels_str, ",")
            for i = 0 to array.size(levels) - 1
                lv_str = str.trim(array.get(levels, i))
                if lv_str != ""
                    lv = str.tonumber(lv_str)
                    if not na(lv)
                        proj_price = cisd_long_lvl + s_range * lv
                        f_reg_line(line.new(bar_index, proj_price, r_end, proj_price, color=proj_color, width=1, style=line.style_dotted))
                        f_reg_label(label.new(r_end, proj_price, str.tostring(lv), color=color.new(proj_color, 100), textcolor=proj_color, style=label.style_label_left, size=size.tiny))
    // SMT divergence label
    if show_smt
        if smt_long
            f_reg_label(label.new(bar_index, sl - (entry - sl) * 0.15, "SMT", color=color.new(color.green, 10), textcolor=color.white, style=label.style_label_up, size=size.small))
        else
            f_reg_label(label.new(bar_index, sl - (entry - sl) * 0.15, "NO SMT", color=color.new(color.gray, 40), textcolor=color.white, style=label.style_label_up, size=size.small))
    // Record drawing counts for this setup and trim oldest if needed
    array.push(setup_line_counts,  array.size(fired_lines)  - _snap_lines)
    array.push(setup_label_counts, array.size(fired_labels) - _snap_labels)
    array.push(setup_box_counts,   array.size(fired_boxes)  - _snap_boxes)
    while array.size(setup_line_counts) > max_setups
        _nl = array.shift(setup_line_counts)
        _nb = array.shift(setup_label_counts)
        _nx = array.shift(setup_box_counts)
        if _nl > 0
            for _i = 1 to _nl
                if array.size(fired_lines) > 0
                    line.delete(array.shift(fired_lines))
        if _nb > 0
            for _i = 1 to _nb
                if array.size(fired_labels) > 0
                    label.delete(array.shift(fired_labels))
        if _nx > 0
            for _i = 1 to _nx
                if array.size(fired_boxes) > 0
                    box.delete(array.shift(fired_boxes))
    _smt_str = show_smt ? (smt_long ? " | SMT" : " | NO SMT") : ""
    _alert_tp = use_split ? "TP1 " + str.tostring(tp, "#.##") + " (" + str.tostring(split_tp1_size, "#") + "%) | TP2 " + str.tostring(_tp2, "#.##") + " (runner)" : "TP " + str.tostring(tp, "#.##")
    alert("LONG " + syminfo.ticker + " | Entry " + str.tostring(entry, "#.##") + " | SL " + str.tostring(sl, "#.##") + " | " + _alert_tp + " | Risk " + str.tostring(long_risk, "#.#") + " pts | " + combo + _smt_str, alert.freq_once_per_bar_close)

// ── FIRE: SHORT ───────────────────────────────────────────────────────────────
if short_valid
    alerted_short := true
    // Clean up own CISD preview
    line.delete(cisd_prev_short)
    cisd_prev_short := na
    label.delete(cisd_prev_lbl_short)
    cisd_prev_lbl_short := na
    // Clean up opposite side's pending drawings
    if not alerted_long
        line.delete(sweep_line_long)
        sweep_line_long := na
        label.delete(sweep_lbl_long)
        sweep_lbl_long := na
        line.delete(cisd_prev_long)
        cisd_prev_long := na
        label.delete(cisd_prev_lbl_long)
        cisd_prev_lbl_long := na
    _snap_lines  := array.size(fired_lines)
    _snap_labels := array.size(fired_labels)
    _snap_boxes  := array.size(fired_boxes)
    entry = close
    // Split profile: SL = min(sweep extreme, entry + entry × MAE p90%)
    _struct_sl = sweep_ext_short
    sl = use_split ? math.min(_struct_sl, entry + entry * split_mae_pct / 100) : _struct_sl
    risk  = sl - entry
    // Split profile: TP1 = entry - entry × PTQ%, TP2 = entry - entry × p50%
    tp    = use_split ? entry - entry * split_ptq_pct / 100 : entry - risk * rr_ratio
    _tp2  = use_split ? entry - entry * split_p50_pct / 100 : float(na)
    _tp1_r = risk > 0 ? (entry - tp) / risk : 0.0
    r_end = bar_index + rr_extend
    // Non-Q1 uses amber/yellow palette
    _is_q1_s  = q1_sweep_short
    _risk_bg  = _is_q1_s ? rr_risk_col    : color.new(#dc2626, 90)
    _risk_br  = _is_q1_s ? rr_risk_border : color.new(#dc2626, 50)
    _rew_bg   = _is_q1_s ? rr_rew_col     : color.new(#eab308, 88)
    _rew_br   = _is_q1_s ? rr_rew_border  : color.new(#eab308, 40)
    _sl_col   = _is_q1_s ? color.red      : #dc2626
    _swp_col  = _is_q1_s ? color.red      : color.orange
    _cisd_col = _is_q1_s ? color.blue     : #eab308
    cisd_bar = bar_index - cisd_short_off
    f_reg_line(line.new(cisd_bar, cisd_short_lvl, r_end, cisd_short_lvl, color=_cisd_col, width=2, style=line.style_solid))
    cisd_x = cisd_lbl_pos == "Right" ? bar_index + rr_extend : cisd_bar
    f_reg_label(label.new(cisd_x, cisd_short_lvl, cisd_text + " " + cisd_tf_lbl + (_is_q1_s ? "" : " *"), color=color.new(_cisd_col, 100), textcolor=_cisd_col, style=cisd_lbl_style, size=size.small))
    if not na(sweep_line_short)
        line.delete(sweep_line_short)
    if not na(sweep_lbl_short)
        label.delete(sweep_lbl_short)
    f_reg_line(line.new(anc_hi_bar, anc_hi, r_end, anc_hi, color=_swp_col, width=2, style=line.style_solid))
    sweep_x = sweep_lbl_pos == "Right" ? r_end : anc_hi_bar
    f_reg_label(label.new(sweep_x, anc_hi, sweep_text + " " + sweep_tf_lbl + (_is_q1_s ? "" : " *"), color=color.new(_swp_col, 100), textcolor=_swp_col, style=sweep_lbl_style, size=size.small))
    sl_anchor = not na(sweep_bar_short) ? sweep_bar_short : bar_index
    f_reg_line(line.new(sl_anchor, sl, r_end, sl, color=_sl_col, width=2, style=sweep_lstyle))
    f_reg_box(box.new(bar_index, sl,    r_end, entry, border_color=_risk_br, bgcolor=_risk_bg))
    f_reg_box(box.new(bar_index, entry, r_end, tp,    border_color=_rew_br,  bgcolor=_rew_bg))
    f_reg_line(line.new(bar_index, entry, r_end, entry, color=rr_entry_col, width=1, style=line.style_solid))
    _tp_lbl = use_split ? "TP1  +" + str.tostring(entry - tp, "#.##") + " pts  " + str.tostring(_tp1_r, "#.#") + "R  (" + str.tostring(split_tp1_size, "#") + "%)" : "TP  +" + str.tostring(risk * rr_ratio, "#.##") + " pts  " + str.tostring(rr_ratio, "#.#") + "R"
    f_reg_label(label.new(bar_index + rr_lbl_x, tp, _tp_lbl, color=rr_lbl_tp_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, entry, "Entry  " + str.tostring(entry, "#.##"), color=rr_lbl_en_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, sl,    "SL  -" + str.tostring(risk, "#.##") + " pts", color=rr_lbl_sl_col, textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    // TP2 runner target (split profile only)
    if use_split and not na(_tp2)
        f_reg_line(line.new(bar_index, _tp2, r_end, _tp2, color=color.new(color.purple, 30), width=1, style=line.style_dotted))
        f_reg_label(label.new(bar_index + rr_lbl_x, _tp2, "TP2  +" + str.tostring(entry - _tp2, "#.##") + " pts  (runner " + str.tostring(100 - split_tp1_size, "#") + "%)", color=color.new(color.purple, 20), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    if show_tspot and not na(sweep_logmid_short) and not na(sweep_close_short)
        tspot_top  = math.max(sweep_logmid_short, sweep_close_short)
        tspot_bot  = math.min(sweep_logmid_short, sweep_close_short)
        sb = not na(sweep_bar_short) ? sweep_bar_short : bar_index
        f_reg_box(box.new(sb, tspot_top, r_end, tspot_bot, bgcolor=color.new(color.red, tspot_transp), border_color=color.new(color.red, tspot_transp + 5)))
        f_reg_line(line.new(sb, sweep_logmid_short, r_end, sweep_logmid_short, color=color.red, width=1, style=line.style_dotted))
    if show_c_labels
        f_reg_label(label.new(anc_hi_bar, anc_hi, "C2", color=color.new(color.red, 100), textcolor=color.red, style=label.style_label_down, size=size.small))
        f_reg_label(label.new(bar_index, cisd_short_lvl, "C3", color=color.new(color.red, 100), textcolor=color.red, style=label.style_label_down, size=size.small))
    if show_tspot_type and not na(sweep_pct_short)
        ttype = sweep_pct_short < 0.30 ? "ProTrend" : sweep_pct_short < 0.80 ? "Normal" : "Expansive"
        f_reg_label(label.new(bar_index, tp, ttype + " SHORT", color=color.new(color.red, 100), textcolor=color.red, style=label.style_label_up, size=size.tiny))
    if show_proj and cisd_short_off > 0
        series_hi = high[cisd_short_off]
        series_lo = low[cisd_short_off]
        for k = 1 to cisd_short_off - 1
            if close[cisd_short_off - k] > open[cisd_short_off - k]
                series_hi := math.max(series_hi, high[cisd_short_off - k])
                series_lo := math.min(series_lo, low[cisd_short_off - k])
            else
                break
        s_range = series_hi - series_lo
        if s_range > 0
            levels = str.split(proj_levels_str, ",")
            for i = 0 to array.size(levels) - 1
                lv_str = str.trim(array.get(levels, i))
                if lv_str != ""
                    lv = str.tonumber(lv_str)
                    if not na(lv)
                        proj_price = cisd_short_lvl - s_range * lv
                        f_reg_line(line.new(bar_index, proj_price, r_end, proj_price, color=proj_color, width=1, style=line.style_dotted))
                        f_reg_label(label.new(r_end, proj_price, str.tostring(lv), color=color.new(proj_color, 100), textcolor=proj_color, style=label.style_label_left, size=size.tiny))
    // SMT divergence label
    if show_smt
        if smt_short
            f_reg_label(label.new(bar_index, sl + (sl - entry) * 0.15, "SMT", color=color.new(color.red, 10), textcolor=color.white, style=label.style_label_down, size=size.small))
        else
            f_reg_label(label.new(bar_index, sl + (sl - entry) * 0.15, "NO SMT", color=color.new(color.gray, 40), textcolor=color.white, style=label.style_label_down, size=size.small))
    // Record drawing counts for this setup and trim oldest if needed
    array.push(setup_line_counts,  array.size(fired_lines)  - _snap_lines)
    array.push(setup_label_counts, array.size(fired_labels) - _snap_labels)
    array.push(setup_box_counts,   array.size(fired_boxes)  - _snap_boxes)
    while array.size(setup_line_counts) > max_setups
        _nl = array.shift(setup_line_counts)
        _nb = array.shift(setup_label_counts)
        _nx = array.shift(setup_box_counts)
        if _nl > 0
            for _i = 1 to _nl
                if array.size(fired_lines) > 0
                    line.delete(array.shift(fired_lines))
        if _nb > 0
            for _i = 1 to _nb
                if array.size(fired_labels) > 0
                    label.delete(array.shift(fired_labels))
        if _nx > 0
            for _i = 1 to _nx
                if array.size(fired_boxes) > 0
                    box.delete(array.shift(fired_boxes))
    _smt_str = show_smt ? (smt_short ? " | SMT" : " | NO SMT") : ""
    _alert_tp = use_split ? "TP1 " + str.tostring(tp, "#.##") + " (" + str.tostring(split_tp1_size, "#") + "%) | TP2 " + str.tostring(_tp2, "#.##") + " (runner)" : "TP " + str.tostring(tp, "#.##")
    alert("SHORT " + syminfo.ticker + " | Entry " + str.tostring(entry, "#.##") + " | SL " + str.tostring(sl, "#.##") + " | " + _alert_tp + " | Risk " + str.tostring(short_risk, "#.#") + " pts | " + combo + _smt_str, alert.freq_once_per_bar_close)

// ── FIRE: OVER-RISK LONG ─────────────────────────────────────────────────────
// Setup is valid but risk exceeds max_risk — drawn muted (gray, dashed, no R:R box)
if long_over
    alerted_long := true
    line.delete(cisd_prev_long)
    cisd_prev_long := na
    label.delete(cisd_prev_lbl_long)
    cisd_prev_lbl_long := na
    if not alerted_short
        line.delete(sweep_line_short)
        sweep_line_short := na
        label.delete(sweep_lbl_short)
        sweep_lbl_short := na
        line.delete(cisd_prev_short)
        cisd_prev_short := na
        label.delete(cisd_prev_lbl_short)
        cisd_prev_lbl_short := na
    _snap_lines  := array.size(fired_lines)
    _snap_labels := array.size(fired_labels)
    _snap_boxes  := array.size(fired_boxes)
    entry = close
    sl    = sweep_ext_long
    risk  = entry - sl
    tp    = entry + risk * rr_ratio
    r_end = bar_index + rr_extend
    _ov_col  = color.new(#ff6600, 30)
    cisd_bar = bar_index - cisd_long_off
    if not na(sweep_line_long)
        line.delete(sweep_line_long)
    if not na(sweep_lbl_long)
        label.delete(sweep_lbl_long)
    f_reg_line(line.new(anc_lo_bar, anc_lo, r_end, anc_lo, color=_ov_col, width=1, style=line.style_dashed))
    sweep_x = sweep_lbl_pos == "Right" ? r_end : anc_lo_bar
    f_reg_label(label.new(sweep_x, anc_lo, sweep_text + " " + sweep_tf_lbl, color=color.new(#ff6600, 100), textcolor=_ov_col, style=sweep_lbl_style, size=size.small))
    f_reg_line(line.new(cisd_bar, cisd_long_lvl, r_end, cisd_long_lvl, color=_ov_col, width=1, style=line.style_dashed))
    cisd_x = cisd_lbl_pos == "Right" ? bar_index + rr_extend : cisd_bar
    f_reg_label(label.new(cisd_x, cisd_long_lvl, cisd_text + " " + cisd_tf_lbl, color=color.new(#ff6600, 100), textcolor=_ov_col, style=cisd_lbl_style, size=size.small))
    sl_anchor = not na(sweep_bar_long) ? sweep_bar_long : bar_index
    f_reg_line(line.new(sl_anchor, sl, r_end, sl, color=_ov_col, width=1, style=line.style_dashed))
    f_reg_line(line.new(bar_index, entry, r_end, entry, color=_ov_col, width=1, style=line.style_dashed))
    f_reg_box(box.new(bar_index, entry, r_end, sl, border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 92)))
    f_reg_box(box.new(bar_index, tp, r_end, entry, border_color=color.new(color.teal, 60), bgcolor=color.new(color.teal, 92)))
    f_reg_label(label.new(bar_index + rr_lbl_x, entry, "Entry  " + str.tostring(entry, "#.##"), color=color.new(#ff6600, 40), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, sl, "SL  -" + str.tostring(risk, "#.##") + " pts", color=color.new(color.red, 30), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, tp, "TP  +" + str.tostring(risk * rr_ratio, "#.##") + " pts  " + str.tostring(rr_ratio, "#.#") + "R", color=color.new(color.teal, 30), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index, tp + (tp - entry) * 0.1, "OVER RISK  " + str.tostring(risk, "#.#") + " pts", color=color.new(#ff6600, 10), textcolor=color.white, style=label.style_label_down, size=size.small))
    array.push(setup_line_counts,  array.size(fired_lines)  - _snap_lines)
    array.push(setup_label_counts, array.size(fired_labels) - _snap_labels)
    array.push(setup_box_counts,   array.size(fired_boxes)  - _snap_boxes)
    while array.size(setup_line_counts) > max_setups
        _nl = array.shift(setup_line_counts)
        _nb = array.shift(setup_label_counts)
        _nx = array.shift(setup_box_counts)
        if _nl > 0
            for _i = 1 to _nl
                if array.size(fired_lines) > 0
                    line.delete(array.shift(fired_lines))
        if _nb > 0
            for _i = 1 to _nb
                if array.size(fired_labels) > 0
                    label.delete(array.shift(fired_labels))
        if _nx > 0
            for _i = 1 to _nx
                if array.size(fired_boxes) > 0
                    box.delete(array.shift(fired_boxes))

// ── FIRE: OVER-RISK SHORT ────────────────────────────────────────────────────
if short_over
    alerted_short := true
    line.delete(cisd_prev_short)
    cisd_prev_short := na
    label.delete(cisd_prev_lbl_short)
    cisd_prev_lbl_short := na
    if not alerted_long
        line.delete(sweep_line_long)
        sweep_line_long := na
        label.delete(sweep_lbl_long)
        sweep_lbl_long := na
        line.delete(cisd_prev_long)
        cisd_prev_long := na
        label.delete(cisd_prev_lbl_long)
        cisd_prev_lbl_long := na
    _snap_lines  := array.size(fired_lines)
    _snap_labels := array.size(fired_labels)
    _snap_boxes  := array.size(fired_boxes)
    entry = close
    sl    = sweep_ext_short
    risk  = sl - entry
    tp    = entry - risk * rr_ratio
    r_end = bar_index + rr_extend
    _ov_col  = color.new(#ff6600, 30)
    cisd_bar = bar_index - cisd_short_off
    if not na(sweep_line_short)
        line.delete(sweep_line_short)
    if not na(sweep_lbl_short)
        label.delete(sweep_lbl_short)
    f_reg_line(line.new(anc_hi_bar, anc_hi, r_end, anc_hi, color=_ov_col, width=1, style=line.style_dashed))
    sweep_x = sweep_lbl_pos == "Right" ? r_end : anc_hi_bar
    f_reg_label(label.new(sweep_x, anc_hi, sweep_text + " " + sweep_tf_lbl, color=color.new(#ff6600, 100), textcolor=_ov_col, style=sweep_lbl_style, size=size.small))
    f_reg_line(line.new(cisd_bar, cisd_short_lvl, r_end, cisd_short_lvl, color=_ov_col, width=1, style=line.style_dashed))
    cisd_x = cisd_lbl_pos == "Right" ? bar_index + rr_extend : cisd_bar
    f_reg_label(label.new(cisd_x, cisd_short_lvl, cisd_text + " " + cisd_tf_lbl, color=color.new(#ff6600, 100), textcolor=_ov_col, style=cisd_lbl_style, size=size.small))
    sl_anchor = not na(sweep_bar_short) ? sweep_bar_short : bar_index
    f_reg_line(line.new(sl_anchor, sl, r_end, sl, color=_ov_col, width=1, style=line.style_dashed))
    f_reg_line(line.new(bar_index, entry, r_end, entry, color=_ov_col, width=1, style=line.style_dashed))
    f_reg_box(box.new(bar_index, sl, r_end, entry, border_color=color.new(color.red, 60), bgcolor=color.new(color.red, 92)))
    f_reg_box(box.new(bar_index, entry, r_end, tp, border_color=color.new(color.teal, 60), bgcolor=color.new(color.teal, 92)))
    f_reg_label(label.new(bar_index + rr_lbl_x, entry, "Entry  " + str.tostring(entry, "#.##"), color=color.new(#ff6600, 40), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, sl, "SL  -" + str.tostring(risk, "#.##") + " pts", color=color.new(color.red, 30), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index + rr_lbl_x, tp, "TP  +" + str.tostring(risk * rr_ratio, "#.##") + " pts  " + str.tostring(rr_ratio, "#.#") + "R", color=color.new(color.teal, 30), textcolor=color.white, style=rr_lbl_style, size=size.tiny))
    f_reg_label(label.new(bar_index, tp - (entry - tp) * 0.1, "OVER RISK  " + str.tostring(risk, "#.#") + " pts", color=color.new(#ff6600, 10), textcolor=color.white, style=label.style_label_up, size=size.small))
    array.push(setup_line_counts,  array.size(fired_lines)  - _snap_lines)
    array.push(setup_label_counts, array.size(fired_labels) - _snap_labels)
    array.push(setup_box_counts,   array.size(fired_boxes)  - _snap_boxes)
    while array.size(setup_line_counts) > max_setups
        _nl = array.shift(setup_line_counts)
        _nb = array.shift(setup_label_counts)
        _nx = array.shift(setup_box_counts)
        if _nl > 0
            for _i = 1 to _nl
                if array.size(fired_lines) > 0
                    line.delete(array.shift(fired_lines))
        if _nb > 0
            for _i = 1 to _nb
                if array.size(fired_labels) > 0
                    label.delete(array.shift(fired_labels))
        if _nx > 0
            for _i = 1 to _nx
                if array.size(fired_boxes) > 0
                    box.delete(array.shift(fired_boxes))
