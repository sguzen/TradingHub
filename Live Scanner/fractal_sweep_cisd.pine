//@version=5
indicator("Abhi's Fractal Sweep", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ── INPUTS ────────────────────────────────────────────────────────────────────
var string G1 = "Model"
combo = input.string("4H/15M", "Timeframe Combo", group=G1,
    options=["1D/1H", "4H/15M", "1H/5M", "1H/3M", "30M/3M"],
    tooltip="Set chart to the CISD (right) timeframe")

var string G2 = "Filters"
sweep_min     = input.float(0.10, "Sweep Min %",           group=G2, step=0.05) / 100
sweep_max     = input.float(1.50, "Sweep Max %",           group=G2, step=0.05) / 100
min_risk      = input.float(3.0,  "Min Risk (pts)",         group=G2)
cisd_lookback = input.int(8,      "CISD Lookback Bars",     group=G2)
rth_only      = input.bool(true,  "RTH Only (07:00-16:00 ET)", group=G2)

var string G3 = "Display"
rr_extend = input.int(20, "R:R Box Width (bars)", group=G3, minval=5, maxval=100)

// ── COMBO → CONFIG ────────────────────────────────────────────────────────────
// q1_bars: fraction of higher-TF candle treated as Q1 (in chart-TF bars)
//   1D/1H  → 14 bars = covers 6pm–8am ET overnight sweep window
//   4H/15M → 4 bars  = first 1h of 4H candle
//   1H/5M  → 3 bars  = first 15m of 1H candle
//   1H/3M  → 5 bars  = first 15m of 1H candle
//   30M/3M → 3 bars  = first ~8m of 30M candle
var string sweep_tf      = "30"
var int    q1_bars       = 3
var string sweep_tf_lbl  = "30M"
var string cisd_tf_lbl   = "3M"
if combo == "1D/1H"
    sweep_tf     := "1D"
    q1_bars      := 14
    sweep_tf_lbl := "1D"
    cisd_tf_lbl  := "1H"
else if combo == "4H/15M"
    sweep_tf     := "240"
    q1_bars      := 4
    sweep_tf_lbl := "4H"
    cisd_tf_lbl  := "15M"
else if combo == "1H/5M"
    sweep_tf     := "60"
    q1_bars      := 3
    sweep_tf_lbl := "1H"
    cisd_tf_lbl  := "5M"
else if combo == "1H/3M"
    sweep_tf     := "60"
    q1_bars      := 5
    sweep_tf_lbl := "1H"
    cisd_tf_lbl  := "3M"

// ── HELPERS ───────────────────────────────────────────────────────────────────
is_rth() =>
    h = hour(time, "America/New_York")
    h >= 7 and h < 16

// ── ANCHOR CANDLE (prior higher-TF bar, fully closed) ─────────────────────────
prior_high  = request.security(syminfo.tickerid, sweep_tf, high[1], lookahead=barmerge.lookahead_on)
prior_low   = request.security(syminfo.tickerid, sweep_tf, low[1],  lookahead=barmerge.lookahead_on)
anchor_time = request.security(syminfo.tickerid, sweep_tf, time,    lookahead=barmerge.lookahead_on)
is_new_anchor = ta.change(anchor_time) != 0

// ── STATE ─────────────────────────────────────────────────────────────────────
var float anc_hi          = na
var float anc_lo          = na
var int   q1_elapsed      = 0
var bool  in_q1           = false

var bool  swept_long      = false
var bool  swept_short     = false
var float sweep_ext_long  = na
var float sweep_ext_short = na

var bool  ret_long        = false
var bool  ret_short       = false

var bool  alerted_long    = false
var bool  alerted_short   = false

// ── ANCHOR RESET ──────────────────────────────────────────────────────────────
if is_new_anchor
    anc_hi          := prior_high
    anc_lo          := prior_low
    q1_elapsed      := 0
    in_q1           := true
    swept_long      := false
    swept_short     := false
    sweep_ext_long  := na
    sweep_ext_short := na
    ret_long        := false
    ret_short       := false
    alerted_long    := false
    alerted_short   := false

// ── Q1 COUNTER ────────────────────────────────────────────────────────────────
if in_q1
    q1_elapsed += 1
    if q1_elapsed >= q1_bars
        in_q1 := false

// ── PHASE 1: SWEEP ────────────────────────────────────────────────────────────
if in_q1 and not na(anc_hi) and not na(anc_lo)
    ref_range = anc_hi - anc_lo
    if ref_range > 0
        // LONG: sweep below prior low
        if not swept_long
            ext = anc_lo - low
            if low < anc_lo and ext / ref_range >= sweep_min and ext / ref_range <= sweep_max
                swept_long     := true
                sweep_ext_long := low
                // Dotted red line at the swept level (prior low)
                line.new(bar_index, anc_lo, bar_index + rr_extend + 15, anc_lo,
                    color=color.red, width=2, style=line.style_dotted)
                label.new(bar_index, anc_lo, "Sweep of " + sweep_tf_lbl,
                    color=color.new(color.red, 100), textcolor=color.red,
                    style=label.style_label_right, size=size.small)

        // SHORT: sweep above prior high
        if not swept_short
            ext = high - anc_hi
            if high > anc_hi and ext / ref_range >= sweep_min and ext / ref_range <= sweep_max
                swept_short     := true
                sweep_ext_short := high
                // Dotted red line at the swept level (prior high)
                line.new(bar_index, anc_hi, bar_index + rr_extend + 15, anc_hi,
                    color=color.red, width=2, style=line.style_dotted)
                label.new(bar_index, anc_hi, "Sweep of " + sweep_tf_lbl,
                    color=color.new(color.red, 100), textcolor=color.red,
                    style=label.style_label_right, size=size.small)

// ── PHASE 2: RETURN TO RANGE ──────────────────────────────────────────────────
if in_q1
    if swept_long  and not ret_long  and close >= anc_lo
        ret_long  := true
    if swept_short and not ret_short and close <= anc_hi
        ret_short := true

// ── PHASE 3: CISD ─────────────────────────────────────────────────────────────
// Walk back to find the consecutive opposing delivery run; fire on close through its open
f_cisd_long() =>
    cisd_lvl  = float(na)
    run_start = 0
    for k = 1 to cisd_lookback
        if close[k] < open[k]
            run_start := k
            break
    if run_start > 0
        for k = run_start + 1 to run_start + cisd_lookback
            if k < bar_index
                if close[k] < open[k] or close[k] == open[k]
                    run_start := k
                else
                    break
        cisd_lvl := open[run_start]
    [not na(cisd_lvl) and close > cisd_lvl, cisd_lvl]

f_cisd_short() =>
    cisd_lvl  = float(na)
    run_start = 0
    for k = 1 to cisd_lookback
        if close[k] > open[k]
            run_start := k
            break
    if run_start > 0
        for k = run_start + 1 to run_start + cisd_lookback
            if k < bar_index
                if close[k] > open[k] or close[k] == open[k]
                    run_start := k
                else
                    break
        cisd_lvl := open[run_start]
    [not na(cisd_lvl) and close < cisd_lvl, cisd_lvl]

[cisd_long_fired,  cisd_long_lvl]  = f_cisd_long()
[cisd_short_fired, cisd_short_lvl] = f_cisd_short()

// ── VALIDITY ──────────────────────────────────────────────────────────────────
long_risk  = not na(sweep_ext_long)  ? math.abs(close - sweep_ext_long)  : 0.0
short_risk = not na(sweep_ext_short) ? math.abs(close - sweep_ext_short) : 0.0

long_valid  = ret_long  and cisd_long_fired  and not alerted_long  and long_risk  >= min_risk
short_valid = ret_short and cisd_short_fired and not alerted_short and short_risk >= min_risk

if rth_only
    long_valid  := long_valid  and is_rth()
    short_valid := short_valid and is_rth()

// ── FIRE: LONG ────────────────────────────────────────────────────────────────
if long_valid
    alerted_long := true
    entry = close
    sl    = sweep_ext_long
    tp    = entry + (entry - sl)   // 1R
    risk  = entry - sl
    r_end = bar_index + rr_extend

    // CISD level — dotted blue line
    line.new(bar_index, cisd_long_lvl, r_end, cisd_long_lvl,
        color=color.blue, width=2, style=line.style_dotted)
    label.new(bar_index, cisd_long_lvl, "CISD " + cisd_tf_lbl,
        color=color.new(color.blue, 100), textcolor=color.blue,
        style=label.style_label_right, size=size.small)

    // R:R — risk zone (red), reward zone (teal), entry line
    box.new(bar_index, entry, r_end, sl,
        border_color=color.new(color.red,  40), bgcolor=color.new(color.red,  85))
    box.new(bar_index, tp,    r_end, entry,
        border_color=color.new(color.teal, 40), bgcolor=color.new(color.teal, 85))
    line.new(bar_index, entry, r_end, entry,
        color=color.white, width=1, style=line.style_solid)
    label.new(r_end, tp,    "TP  +" + str.tostring(risk, "#.##") + " pts  1R",
        color=color.new(color.teal, 20), textcolor=color.white,
        style=label.style_label_left, size=size.tiny)
    label.new(r_end, entry, "Entry  " + str.tostring(entry, "#.##"),
        color=color.new(color.gray, 60), textcolor=color.white,
        style=label.style_label_left, size=size.tiny)
    label.new(r_end, sl,    "SL  -" + str.tostring(risk, "#.##") + " pts",
        color=color.new(color.red,  20), textcolor=color.white,
        style=label.style_label_left, size=size.tiny)

    alert("LONG " + syminfo.ticker + " | Entry " + str.tostring(entry, "#.##") +
        " | SL " + str.tostring(sl, "#.##") + " | TP " + str.tostring(tp, "#.##") +
        " | Risk " + str.tostring(long_risk, "#.#") + " pts | " + combo,
        alert.freq_once_per_bar_close)

// ── FIRE: SHORT ───────────────────────────────────────────────────────────────
if short_valid
    alerted_short := true
    entry = close
    sl    = sweep_ext_short
    tp    = entry - (sl - entry)   // 1R
    risk  = sl - entry
    r_end = bar_index + rr_extend

    // CISD level — dotted blue line
    line.new(bar_index, cisd_short_lvl, r_end, cisd_short_lvl,
        color=color.blue, width=2, style=line.style_dotted)
    label.new(bar_index, cisd_short_lvl, "CISD " + cisd_tf_lbl,
        color=color.new(color.blue, 100), textcolor=color.blue,
        style=label.style_label_right, size=size.small)

    // R:R — risk zone (red), reward zone (teal), entry line
    box.new(bar_index, sl,    r_end, entry,
        border_color=color.new(color.red,  40), bgcolor=color.new(color.red,  85))
    box.new(bar_index, entry, r_end, tp,
        border_color=color.new(color.teal, 40), bgcolor=color.new(color.teal, 85))
    line.new(bar_index, entry, r_end, entry,
        color=color.white, width=1, style=line.style_solid)
    label.new(r_end, tp,    "TP  +" + str.tostring(risk, "#.##") + " pts  1R",
        color=color.new(color.teal, 20), textcolor=color.white,
        style=label.style_label_left, size=size.tiny)
    label.new(r_end, entry, "Entry  " + str.tostring(entry, "#.##"),
        color=color.new(color.gray, 60), textcolor=color.white,
        style=label.style_label_left, size=size.tiny)
    label.new(r_end, sl,    "SL  -" + str.tostring(risk, "#.##") + " pts",
        color=color.new(color.red,  20), textcolor=color.white,
        style=label.style_label_left, size=size.tiny)

    alert("SHORT " + syminfo.ticker + " | Entry " + str.tostring(entry, "#.##") +
        " | SL " + str.tostring(sl, "#.##") + " | TP " + str.tostring(tp, "#.##") +
        " | Risk " + str.tostring(short_risk, "#.#") + " pts | " + combo,
        alert.freq_once_per_bar_close)
