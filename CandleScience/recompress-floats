import pandas as pd

df = pd.read_csv("yourfile.csv")
print(df.columns.tolist())  # paste output here so I can help pick what to drop
print(df.shape)

# Round floats to 2 decimal places (plenty for price data)
float_cols = df.select_dtypes(include='float').columns
df[float_cols] = df[float_cols].round(2)

df.to_csv("yourfile_smaller.csv", index=False)