gShowHourVerd = input.bool(true,  "Show hour close verdict", group=G_VER)
gPillRetention= input.string("Current and previous", "Hour close pill retention",
                              options=["Current", "Current and previous", "All"], group=G_VER,
                              tooltip="How many hour-close pills stay on chart. 'All' keeps every closed-hour pill (bounded by TradingView's max_labels_count cap).")
gShowTriadVerd= input.bool(true,  "Show triad close verdict", group=G_VER)
gShowApexHr   = input.bool(true,  "Show apex-hour highlight", group=G_VER)
