gColQ3Bg      = input.color(color.new(#64748b, 88),       "Q3 background", group=G_QS)
gColQ4Bg      = input.color(color.new(color.white, 100), "Q4 background", group=G_QS)

// ── 🕒 Hour & Triad Verdicts ─────────────────────────────────────────────
