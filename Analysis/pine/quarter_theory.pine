//@version=6
indicator("Abhi's Live Price Action", overlay=true,
         max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║ Abhi's Live Price Action — intraday price-action structure overlay       ║
// ║ 15m quarters · 1h doji/line · 3h triad line/apex · 05-box bands · midlns ║
// ╚══════════════════════════════════════════════════════════════════════════╝


