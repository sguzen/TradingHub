gShowHourOpenBox = input.bool(true, "Show hour-open minute box (gray strip at :00)", group=G_QS)
gColHourOpenBox  = input.color(color.new(#94a3b8, 75), "Hour-open minute box color", group=G_QS)
// Per-quarter background colors. Q1/Q2/Q4 default to fully transparent so the
// hour shows as clear; Q3 defaults to a faint cyan/teal wash so the eye picks
